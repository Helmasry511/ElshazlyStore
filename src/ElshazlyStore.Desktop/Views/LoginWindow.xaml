<Window x:Class="ElshazlyStore.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
        xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:LoginViewModel}"
        Title="{Binding Title}"
        Width="420" Height="520"
        MinWidth="380" MinHeight="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/app-icon.jpg"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid>
        <!-- Center card -->
        <Border VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="340"
                Style="{StaticResource CardStyle}"
                Padding="28">
            <StackPanel>

                <!-- ═══ Logo / Title ═══ -->
                <TextBlock Text="{x:Static loc:Strings.AppName}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeTitle}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <TextBlock Text="{x:Static loc:Strings.AppSubtitle}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeLarge}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />

                <TextBlock Text="{x:Static loc:Strings.Login_Subtitle}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource DisabledTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28" />

                <!-- ═══ Username ═══ -->
                <TextBlock Text="{x:Static loc:Strings.Login_Username}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,6" />

                <Border BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource SmallCornerRadius}"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        Padding="2"
                        Margin="0,0,0,16">
                    <TextBox x:Name="UsernameBox"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{StaticResource PrimaryFont}"
                             FontSize="{StaticResource FontSizeNormal}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="8,6"
                             CaretBrush="{DynamicResource AccentBrush}"
                             FlowDirection="LeftToRight"
                             MaxLength="100"
                             TabIndex="0" />
                </Border>

                <!-- ═══ Password ═══ -->
                <TextBlock Text="{x:Static loc:Strings.Login_Password}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,0,0,6" />

                <Border BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource SmallCornerRadius}"
                        Background="{DynamicResource ContentBackgroundBrush}"
                        Padding="2"
                        Margin="0,0,0,20">
                    <PasswordBox x:Name="PasswordBox"
                                 FontFamily="{StaticResource PrimaryFont}"
                                 FontSize="{StaticResource FontSizeNormal}"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="8,6"
                                 CaretBrush="{DynamicResource AccentBrush}"
                                 FlowDirection="LeftToRight"
                                 MaxLength="200"
                                 TabIndex="1" />
                </Border>

                <!-- ═══ Error message ═══ -->
                <Border Margin="0,0,0,12"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisConv}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="{StaticResource FontSizeSmall}"
                               Foreground="{DynamicResource ErrorBrush}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center" />
                </Border>

                <!-- ═══ Login button ═══ -->
                <Button x:Name="LoginButton"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Height="40"
                        TabIndex="2"
                        IsDefault="True">
                    <Grid>
                        <!-- Normal text -->
                        <TextBlock Text="{x:Static loc:Strings.Login_SignIn}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsBusy, Converter={StaticResource InverseBoolToVisConv}}" />
                        <!-- Loading text -->
                        <TextBlock Text="{x:Static loc:Strings.Login_SigningIn}"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisConv}}" />
                    </Grid>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
