<Window x:Class="ElshazlyStore.Desktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
        xmlns:pages="clr-namespace:ElshazlyStore.Desktop.Views.Pages"
        xmlns:helpers="clr-namespace:ElshazlyStore.Desktop.Helpers"
        xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="{Binding Title}"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="780"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/app-icon.jpg"
        FlowDirection="RightToLeft"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <helpers:StringEqualityToVisibilityConverter x:Key="StringEqVisConv" />

        <!-- DataTemplates for content region -->
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <pages:HomePage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <pages:SettingsPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
            <pages:ProductsPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VariantsViewModel}">
            <pages:VariantsPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomersViewModel}">
            <pages:CustomersPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SuppliersViewModel}">
            <pages:SuppliersPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WarehousesViewModel}">
            <pages:WarehousesPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockBalancesViewModel}">
            <pages:StockBalancesPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockLedgerViewModel}">
            <pages:StockLedgerPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StockMovementsViewModel}">
            <pages:StockMovementsPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PurchasesViewModel}">
            <pages:PurchasesPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesViewModel}">
            <pages:SalesPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:POSViewModel}">
            <pages:POSPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PurchaseReturnsViewModel}">
            <pages:PurchaseReturnsPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SalesReturnsViewModel}">
            <pages:SalesReturnsPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReasonCodesViewModel}">
            <pages:ReasonCodesPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SupplierPaymentsViewModel}">
            <pages:SupplierPaymentsPage DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CustomerPaymentsViewModel}">
            <pages:CustomerPaymentsPage DataContext="{Binding}" />
        </DataTemplate>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- ═══ TOP BAR ═══ -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource TopBarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Height="48"
                SnapsToDevicePixels="True">
            <DockPanel Margin="16,0">

                <!-- App title -->
                <TextBlock Text="{x:Static loc:Strings.AppName}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeMedium}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left" />

                <!-- Right-side controls -->
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            VerticalAlignment="Center">

                    <!-- Current user display -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,12,0"
                                Visibility="{Binding HasUser, Converter={StaticResource BoolToVisConv}}">
                        <Path Data="M12,12 C14.21,12 16,10.21 16,8 C16,5.79 14.21,4 12,4 C9.79,4 8,5.79 8,8 C8,10.21 9.79,12 12,12 Z M12,14 C9.33,14 4,15.34 4,18 V20 H20 V18 C20,15.34 14.67,14 12,14 Z"
                              Fill="{DynamicResource SecondaryTextBrush}"
                              Width="16" Height="16"
                              Stretch="Uniform"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center" />
                        <TextBlock Text="{Binding CurrentUsername}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Logout button -->
                    <Button Command="{Binding LogoutCommand}"
                            ToolTip="{x:Static loc:Strings.Action_SignOut}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Width="36" Height="36"
                            Visibility="{Binding HasUser, Converter={StaticResource BoolToVisConv}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="{StaticResource SmallCornerRadius}"
                                        SnapsToDevicePixels="True">
                                    <Path Data="M17,7 L15.59,8.41 L18.17,11 H8 V13 H18.17 L15.59,15.58 L17,17 L22,12 L17,7 Z M4,5 H12 V3 H4 C2.9,3 2,3.9 2,5 V19 C2,20.1 2.9,21 4,21 H12 V19 H4 V5 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                                Value="{DynamicResource NavItemHoverBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Theme toggle -->
                    <ToggleButton IsChecked="{Binding IsDarkMode, Mode=TwoWay}"
                                  Style="{StaticResource ThemeToggleButtonStyle}" />
                </StackPanel>

                <!-- Spacer -->
                <Border />
            </DockPanel>
        </Border>

        <!-- ═══ SIDEBAR ═══ -->
        <Border DockPanel.Dock="Left"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Width="220"
                SnapsToDevicePixels="True">
            <DockPanel>

                <!-- Bottom section: Settings -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,8">
                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Margin="12,4" />

                    <Button Command="{Binding NavigateToCommand}"
                            CommandParameter="Settings"
                            Style="{StaticResource NavButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12,15.5 A3.5,3.5 0 1,1 12,8.5 A3.5,3.5 0 1,1 12,15.5 Z M19.43,12.98 C19.47,12.66 19.5,12.34 19.5,12 C19.5,11.66 19.47,11.34 19.43,11.02 L21.54,9.37 C21.73,9.22 21.78,8.95 21.66,8.73 L19.66,5.27 C19.54,5.05 19.27,4.97 19.05,5.05 L16.56,6.05 C16.04,5.65 15.48,5.32 14.87,5.07 L14.49,2.42 C14.46,2.18 14.25,2 14,2 L10,2 C9.75,2 9.54,2.18 9.51,2.42 L9.13,5.07 C8.52,5.32 7.96,5.66 7.44,6.05 L4.95,5.05 C4.73,4.96 4.46,5.05 4.34,5.27 L2.34,8.73 C2.21,8.95 2.27,9.22 2.46,9.37 L4.57,11.02 C4.53,11.34 4.5,11.67 4.5,12 C4.5,12.33 4.53,12.66 4.57,12.98 L2.46,14.63 C2.27,14.78 2.21,15.05 2.34,15.27 L4.34,18.73 C4.46,18.95 4.73,19.03 4.95,18.95 L7.44,17.95 C7.96,18.35 8.52,18.68 9.13,18.93 L9.51,21.58 C9.54,21.82 9.75,22 10,22 L14,22 C14.25,22 14.46,21.82 14.49,21.58 L14.87,18.93 C15.48,18.68 16.04,18.34 16.56,17.95 L19.05,18.95 C19.27,19.04 19.54,18.95 19.66,18.73 L21.66,15.27 C21.78,15.05 21.73,14.78 21.54,14.63 L19.43,12.98 Z"
                                  Fill="{DynamicResource SecondaryTextBrush}"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  Margin="0,0,10,0"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{x:Static loc:Strings.Nav_Settings}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Main nav items -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="0,8">
                    <StackPanel>

                        <!-- ═══ MAIN Section ═══ -->
                        <TextBlock Text="{x:Static loc:Strings.Section_Main}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource DisabledTextBrush}"
                                   Margin="16,12,0,4" />

                        <!-- Home (always visible) -->
                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="Home"
                                Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M10,20 V14 H14 V20 H19 V12 H22 L12,3 L2,12 H5 V20 Z"
                                      Fill="{DynamicResource SecondaryTextBrush}"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      Margin="0,0,10,0"
                                      VerticalAlignment="Center" />
                                <TextBlock Text="{x:Static loc:Strings.Nav_Home}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Dashboard -->
                        <Button Command="{Binding NavigateToCommand}"
                                CommandParameter="Dashboard"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding CanViewDashboard, Converter={StaticResource BoolToVisConv}}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M3,13 H11 V3 H3 V13 Z M3,21 H11 V15 H3 V21 Z M13,21 H21 V11 H13 V21 Z M13,3 V9 H21 V3 H13 Z"
                                      Fill="{DynamicResource SecondaryTextBrush}"
                                      Width="16" Height="16"
                                      Stretch="Uniform"
                                      Margin="0,0,10,0"
                                      VerticalAlignment="Center" />
                                <TextBlock Text="{x:Static loc:Strings.Nav_Dashboard}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- ═══ COMMERCE Section ═══ -->
                        <StackPanel Visibility="{Binding CanViewCommerce, Converter={StaticResource BoolToVisConv}}">
                            <TextBlock Text="{x:Static loc:Strings.Section_Commerce}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DisabledTextBrush}"
                                       Margin="16,20,0,4" />

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="Products"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewProducts, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M20,2 H4 C2.9,2 2,2.9 2,4 V22 L6,18 H20 C21.1,18 22,17.1 22,16 V4 C22,2.9 21.1,2 20,2 Z M6,9 H18 V11 H6 V9 Z M14,14 H6 V12 H14 V14 Z M18,8 H6 V6 H18 V8 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_Products}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="Variants"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewProducts, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M4,6 H2 V20 C2,21.1 2.9,22 4,22 H18 V20 H4 V6 Z M20,2 H8 C6.9,2 6,2.9 6,4 V16 C6,17.1 6.9,18 8,18 H20 C21.1,18 22,17.1 22,16 V4 C22,2.9 21.1,2 20,2 Z M20,16 H8 V4 H20 V16 Z M10,9 H18 V11 H10 V9 Z M10,12 H14 V14 H10 V12 Z M10,6 H18 V8 H10 V6 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_Variants}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="Customers"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewCustomers, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M16,11 C17.66,11 18.99,9.66 18.99,8 C18.99,6.34 17.66,5 16,5 C14.34,5 13,6.34 13,8 C13,9.66 14.34,11 16,11 Z M8,11 C9.66,11 10.99,9.66 10.99,8 C10.99,6.34 9.66,5 8,5 C6.34,5 5,6.34 5,8 C5,9.66 6.34,11 8,11 Z M8,13 C5.67,13 1,14.17 1,16.5 V19 H15 V16.5 C15,14.17 10.33,13 8,13 Z M16,13 C15.71,13 15.38,13.02 15.03,13.05 C16.19,13.89 17,15.02 17,16.5 V19 H23 V16.5 C23,14.17 18.33,13 16,13 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_Customers}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="Suppliers"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewSuppliers, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M20,8 H17 V4 H3 C1.9,4 1,4.9 1,6 V17 H3 C3,18.66 4.34,20 6,20 C7.66,20 9,18.66 9,17 H15 C15,18.66 16.34,20 18,20 C19.66,20 21,18.66 21,17 H23 V12 L20,8 Z M6,18.5 C5.17,18.5 4.5,17.83 4.5,17 C4.5,16.17 5.17,15.5 6,15.5 C6.83,15.5 7.5,16.17 7.5,17 C7.5,17.83 6.83,18.5 6,18.5 Z M19.5,9.5 L21.46,12 H17 V9.5 H19.5 Z M18,18.5 C17.17,18.5 16.5,17.83 16.5,17 C16.5,16.17 17.17,15.5 18,15.5 C18.83,15.5 19.5,16.17 19.5,17 C19.5,17.83 18.83,18.5 18,18.5 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_Suppliers}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- ═══ INVENTORY Section ═══ -->
                        <StackPanel Visibility="{Binding CanViewInventory, Converter={StaticResource BoolToVisConv}}">
                            <TextBlock Text="{x:Static loc:Strings.Section_Inventory}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DisabledTextBrush}"
                                       Margin="16,20,0,4" />

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="Warehouses"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewWarehouses, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M22,21 V7 L12,1 L2,7 V21 H10 V13 H14 V21 H22 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_Warehouses}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="StockBalances"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewStock, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M19,3 H5 C3.89,3 3,3.9 3,5 V19 C3,20.1 3.89,21 5,21 H19 C20.11,21 21,20.1 21,19 V5 C21,3.9 20.11,3 19,3 Z M9,17 H7 V10 H9 V17 Z M13,17 H11 V7 H13 V17 Z M17,17 H15 V13 H17 V17 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_StockBalances}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="StockLedger"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewStock, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M14,2 H6 C4.9,2 4,2.9 4,4 V20 C4,21.1 4.89,22 5.99,22 H18 C19.1,22 20,21.1 20,20 V8 L14,2 Z M16,18 H8 V16 H16 V18 Z M16,14 H8 V12 H16 V14 Z M13,9 V3.5 L18.5,9 H13 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_StockLedger}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="StockMovements"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewStockPost, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M19,15 L13,21 V18 H6 V12 H13 V9 L19,15 Z M5,3 H19 C20.1,3 21,3.9 21,5 V10.17 L19,12.17 V5 H5 V19 H12.17 L14.17,21 H5 C3.9,21 3,20.1 3,19 V5 C3,3.9 3.9,3 5,3 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_StockMovements}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="Purchases"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewPurchases, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M18,6 H16 C16,3.79 14.21,2 12,2 C9.79,2 8,3.79 8,6 H6 C4.9,6 4,6.9 4,8 V20 C4,21.1 4.9,22 6,22 H18 C19.1,22 20,21.1 20,20 V8 C20,6.9 19.1,6 18,6 Z M12,4 C13.1,4 14,4.9 14,6 H10 C10,4.9 10.9,4 12,4 Z M18,20 H6 V8 H18 V20 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_Purchases}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="Production"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewProduction, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M19.13,12.66 C19.15,12.45 19.17,12.23 19.17,12 C19.17,11.77 19.15,11.55 19.13,11.34 L21.16,9.76 C21.34,9.62 21.39,9.36 21.28,9.16 L19.36,5.84 C19.24,5.64 18.99,5.56 18.79,5.64 L16.42,6.58 C16.06,6.3 15.65,6.07 15.22,5.88 L14.88,3.37 C14.85,3.15 14.66,3 14.44,3 H10.6 C10.36,3 10.18,3.15 10.15,3.37 L9.81,5.88 C9.38,6.07 8.97,6.31 8.6,6.58 L6.23,5.64 C6.02,5.55 5.78,5.64 5.66,5.84 L3.74,9.16 C3.62,9.36 3.67,9.62 3.86,9.76 L5.89,11.34 C5.87,11.55 5.85,11.78 5.85,12 C5.85,12.22 5.87,12.45 5.89,12.66 L3.86,14.24 C3.68,14.38 3.63,14.64 3.74,14.84 L5.66,18.16 C5.78,18.36 6.03,18.44 6.23,18.36 L8.6,17.42 C8.96,17.7 9.37,17.93 9.8,18.12 L10.14,20.63 C10.18,20.85 10.36,21 10.6,21 H14.44 C14.67,21 14.86,20.85 14.88,20.63 L15.22,18.12 C15.65,17.93 16.06,17.69 16.43,17.42 L18.8,18.36 C19.01,18.45 19.25,18.36 19.37,18.16 L21.29,14.84 C21.41,14.64 21.36,14.38 21.17,14.24 L19.13,12.66 Z M12.5,15.5 C10.57,15.5 9,13.93 9,12 C9,10.07 10.57,8.5 12.5,8.5 C14.43,8.5 16,10.07 16,12 C16,13.93 14.43,15.5 12.5,15.5 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_Production}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- ═══ SALES Section ═══ -->
                        <StackPanel Visibility="{Binding CanViewSales, Converter={StaticResource BoolToVisConv}}">
                            <TextBlock Text="{x:Static loc:Strings.Section_Sales}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource DisabledTextBrush}"
                                       Margin="16,20,0,4" />

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="Sales"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewSalesRead, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M19,3 H5 C3.89,3 3,3.9 3,5 V19 C3,20.1 3.89,21 5,21 H19 C20.11,21 21,20.1 21,19 V5 C21,3.9 20.11,3 19,3 Z M9,17 H7 V10 H9 V17 Z M13,17 H11 V7 H13 V17 Z M17,17 H15 V13 H17 V17 Z"
                                          Fill="{DynamicResource SecondaryTextBrush}"
                                          Width="16" Height="16"
                                          Stretch="Uniform"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Static loc:Strings.Nav_Sales}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToCommand}"
                                    CommandParameter="SalesPos"
                                    Style="{StaticResource NavButtonStyle}"
                                    Visibility="{Binding CanViewSalesPos, Converter={StaticResource BoolToVisConv}}">
