<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.VariantsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:VariantsViewModel}"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <!-- Main list view (always visible) -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Page title -->
            <TextBlock Grid.Row="0" Text="{x:Static loc:Strings.Nav_Variants}"
                       Style="{StaticResource PageTitleStyle}"
                       HorizontalAlignment="Center"
                       Margin="24,16,24,8" />

            <!-- Unified toolbar: Create + Refresh + Search mode + TextBox + Search + Clear -->
            <DockPanel Grid.Row="1" Margin="24,0,24,8">
                <Button Content="{x:Static loc:Strings.Action_Create}"
                        Command="{Binding OpenCreateCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Visibility="{Binding CanWrite, Converter={StaticResource BoolToVisConv}}" />
                <Button Content="{x:Static loc:Strings.Action_Refresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_RefreshQuantities}"
                        Command="{Binding RefreshQuantitiesCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0"
                        ToolTip="{x:Static loc:Strings.Action_RefreshQuantities}" />
                <Button Content="{x:Static loc:Strings.Action_Search}"
                        Command="{Binding UnifiedSearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_Clear}"
                        Command="{Binding ClearUnifiedSearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <ComboBox ItemsSource="{Binding SearchModes}"
                          SelectedItem="{Binding SelectedSearchMode}"
                          DockPanel.Dock="Left"
                          Margin="8,0,0,0"
                          MinWidth="100"
                          VerticalContentAlignment="Center"
                          FontFamily="{StaticResource PrimaryFont}"
                          FontSize="{StaticResource FontSizeNormal}" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"
                         DockPanel.Dock="Right"
                         Margin="8,0,0,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding UnifiedSearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Border />
            </DockPanel>

            <!-- Warehouse filter row -->
            <DockPanel Grid.Row="2" Margin="24,0,24,8">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="{x:Static loc:Strings.Field_Warehouse}"
                               Style="{StaticResource FormLabelStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding Warehouses}"
                              SelectedItem="{Binding SelectedWarehouse}"
                              DisplayMemberPath="DisplayText"
                              MinWidth="180"
                              VerticalContentAlignment="Center"
                              FontFamily="{StaticResource PrimaryFont}"
                              FontSize="{StaticResource FontSizeNormal}" />
                    <Button Content="{x:Static loc:Strings.Action_Search}"
                            Command="{Binding FilterByWarehouseCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="12,8"
                            Margin="4,0,0,0" />
                </StackPanel>
                <TextBlock Text="{Binding WarehouseFilterModeLabel}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"
                           Margin="16,0,0,0" />
                <Border />
            </DockPanel>

            <!-- Barcode lookup result card -->
            <Border Grid.Row="3" Margin="24,0,24,8"
                    Visibility="{Binding HasLookupResult, Converter={StaticResource BoolToVisConv}}"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource MediumCornerRadius}"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static loc:Strings.Field_ProductName}" Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding LookupResult.ProductName}" />
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="{x:Static loc:Strings.Field_Sku}" Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Row="0" Grid.Column="6" Text="{Binding LookupResult.Sku}" FlowDirection="LeftToRight" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static loc:Strings.Field_Color}" Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding LookupResult.Color}" />
                    <TextBlock Grid.Row="1" Grid.Column="4" Text="{x:Static loc:Strings.Field_RetailPrice}" Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Row="1" Grid.Column="6" Text="{Binding LookupResult.RetailPrice, StringFormat=N2}" FlowDirection="LeftToRight" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static loc:Strings.Field_Status}" Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding LookupResult.Status}" />
                    <TextBlock Grid.Row="2" Grid.Column="4" Text="{x:Static loc:Strings.Field_Barcode}" Style="{StaticResource FormLabelStyle}" />
                    <TextBlock Grid.Row="2" Grid.Column="6" Text="{Binding LookupResult.Barcode}" FlowDirection="LeftToRight" />
                </Grid>
            </Border>

            <!-- Barcode lookup error message -->
            <TextBlock Grid.Row="3" Margin="24,0,24,8"
                       Text="{Binding LookupMessage}"
                       Foreground="{DynamicResource ErrorBrush}"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="{StaticResource FontSizeSmall}"
                       TextWrapping="Wrap"
                       Visibility="{Binding LookupMessage, Converter={StaticResource StringNotEmptyToVis}}" />

            <!-- DataGrid -->
            <DataGrid x:Name="VariantsGrid" Grid.Row="4"
                      ItemsSource="{Binding Items}"
                      Style="{StaticResource ThemedDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      Margin="24,0"
                      Visibility="{Binding HasError, Converter={StaticResource InverseBoolToVisConv}}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource ThemedDataGridRowStyle}">
                        <EventSetter Event="MouseDoubleClick" Handler="OnRowDoubleClick" />
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Sku}" Binding="{Binding Sku}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_ProductName}" Binding="{Binding ProductName}" Width="2*" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Color}" Binding="{Binding Color}" Width="80" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Size}" Binding="{Binding Size}" Width="80" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_RetailPrice}" Binding="{Binding RetailPrice, StringFormat=N2}" Width="100" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_WholesalePrice}" Binding="{Binding WholesalePrice, StringFormat=N2}" Width="100" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Barcode}" Binding="{Binding Barcode}" Width="140">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="{x:Static loc:Strings.Field_Quantity}" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding QuantityDisplay}" FlowDirection="LeftToRight"
                                           HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding QuantityDisplay}" Value="0">
                                                    <Setter Property="ToolTip" Value="{x:Static loc:Strings.Stock_QuantityOtherWarehouse}" />
                                                    <Setter Property="Foreground" Value="#999999" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Status}" Binding="{Binding IsActive, Converter={StaticResource BoolToActiveStatus}}" Width="80" />
                    <DataGridTemplateColumn Header="{x:Static loc:Strings.Field_Actions}" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="{x:Static loc:Strings.Action_Edit}"
                                            Command="{Binding DataContext.OpenEditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanWrite, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}" />
                                    <Button Content="{x:Static loc:Strings.Action_Delete}"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanWrite, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty / Error states -->
            <controls:EmptyState Grid.Row="4"
                                 Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisConv}}" />
            <controls:ErrorDisplay Grid.Row="4"
                                   Message="{Binding ErrorMessage}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisConv}}" />

            <!-- Paging -->
            <DockPanel Grid.Row="5" Margin="24,8">
                <TextBlock Text="{Binding PagingInfo}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="{x:Static loc:Strings.Paging_First}" Command="{Binding FirstPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Next}" Command="{Binding NextPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Last}" Command="{Binding LastPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                </StackPanel>
                <Border />
            </DockPanel>
        </Grid>

        <!-- ═══ MODAL: Edit / Create form ═══ -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConv}}">
            <!-- Dim backdrop -->
            <Border Background="#80000000" />
            <!-- Centered card -->
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560">
                    <StackPanel Margin="24,20" MaxWidth="500">
                        <!-- Modal header with close button -->
                        <DockPanel Margin="0,0,0,16">
                            <Button Content="✕"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    DockPanel.Dock="Left"
                                    FontSize="14" />
                            <TextBlock Text="{x:Static loc:Strings.Variants_FormTitle}"
                                       Style="{StaticResource PageTitleStyle}"
                                       HorizontalAlignment="Center"
                                       Margin="0" />
                        </DockPanel>

                        <!-- ═══ Product Picker ═══ -->
                        <TextBlock Text="{x:Static loc:Strings.Field_ProductName}" Style="{StaticResource FormLabelStyle}" />

                        <!-- Selected product display (when a product is selected) -->
                        <Border Visibility="{Binding IsProductSelected, Converter={StaticResource BoolToVisConv}}"
                                Background="{DynamicResource SidebarBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource SmallCornerRadius}"
                                Padding="10,8"
                                Margin="0,0,0,12">
                            <DockPanel>
                                <Button Content="✕"
                                        Command="{Binding ClearProductSelectionCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="6,2"
                                        DockPanel.Dock="Left"
                                        Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisConv}}" />
                                <TextBlock Text="{Binding SelectedProductName}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="{StaticResource FontSizeNormal}"
                                           VerticalAlignment="Center"
                                           Margin="8,0,0,0" />
                            </DockPanel>
                        </Border>

                        <!-- Product search (when no product is selected) -->
                        <StackPanel Visibility="{Binding IsProductSelected, Converter={StaticResource InverseBoolToVisConv}}">
                            <DockPanel Margin="0,0,0,4">
                                <Button Content="{x:Static loc:Strings.Action_Search}"
                                        Command="{Binding SearchProductsCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,6"
                                        DockPanel.Dock="Left"
                                        Margin="4,0,0,0" />
                                <TextBox Text="{Binding ProductSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ThemedTextBoxStyle}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding SearchProductsCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                            </DockPanel>
                            <ListBox ItemsSource="{Binding ProductSearchResults}"
                                     MaxHeight="150"
                                     BorderBrush="{DynamicResource BorderBrush}"
                                     BorderThickness="1"
                                     Background="{DynamicResource ContentBackgroundBrush}"
                                     Margin="0,0,0,12"
                                     Visibility="{Binding HasProductSearchResults, Converter={StaticResource BoolToVisConv}}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.SelectProductCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                              CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="{StaticResource FontSizeNormal}" />
                                                <TextBlock Text="{Binding Category}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="{StaticResource FontSizeSmall}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <!-- Read-only Default Warehouse from selected product -->
                        <Border Visibility="{Binding IsProductSelected, Converter={StaticResource BoolToVisConv}}"
                                Background="{DynamicResource SidebarBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource SmallCornerRadius}"
                                Padding="10,8"
                                Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{x:Static loc:Strings.Variant_DefaultWarehouseLabel}"
                                           Style="{StaticResource FormLabelStyle}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="{Binding FormDefaultWarehouseName}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="{StaticResource FontSizeNormal}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{x:Static loc:Strings.Field_Sku}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormSku, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,2"
                                 FlowDirection="LeftToRight" />
                        <TextBlock Text="{x:Static loc:Strings.Sku_HelperText}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,12"
                                   Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisConv}}" />

                        <TextBlock Text="{x:Static loc:Strings.Field_Barcode}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormBarcode, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,2"
                                 FlowDirection="LeftToRight"
                                 IsReadOnly="{Binding IsEditMode}"
                                 IsEnabled="{Binding IsEditMode, Converter={StaticResource InvBool}}" />
                        <TextBlock Text="{x:Static loc:Strings.Barcode_HelperText}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,12"
                                   Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisConv}}" />

                        <TextBlock Text="{x:Static loc:Strings.Field_Color}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormColor, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,12" />

                        <TextBlock Text="{x:Static loc:Strings.Field_Size}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormSize, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,12" />

                        <TextBlock Text="{x:Static loc:Strings.Field_RetailPrice}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormRetailPrice, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,12"
                                 FlowDirection="LeftToRight" />

                        <TextBlock Text="{x:Static loc:Strings.Field_WholesalePrice}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormWholesalePrice, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,12"
                                 FlowDirection="LeftToRight" />

                        <!-- IsActive toggle (edit mode only) -->
                        <CheckBox Content="{x:Static loc:Strings.Field_IsActive}"
                                  IsChecked="{Binding FormIsActive}"
                                  FontFamily="{StaticResource PrimaryFont}"
                                  FontSize="{StaticResource FontSizeNormal}"
                                  Margin="0,0,0,12"
                                  Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisConv}}" />

                        <!-- Error message -->
                        <TextBlock Text="{Binding FormError}"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"
                                   Visibility="{Binding FormError, Converter={StaticResource StringNotEmptyToVis}}" />

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="{x:Static loc:Strings.Action_Save}"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="24,8" Margin="0,0,8,0"
                                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvBool}}" />
                            <Button Content="{x:Static loc:Strings.Action_Cancel}"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="24,8" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ MODAL: Balance Details (double-click) ═══ -->
        <Grid Visibility="{Binding IsShowingBalanceDetails, Converter={StaticResource BoolToVisConv}}">
            <!-- Dim backdrop -->
            <Border Background="#80000000" />
            <!-- Centered card -->
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="620"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0">
                <StackPanel Margin="24,20" MaxWidth="580">
                    <!-- Modal header with close button -->
                    <DockPanel Margin="0,0,0,16">
                        <Button Content="✕"
                                Command="{Binding CloseBalanceDetailsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="8,4"
                                DockPanel.Dock="Left"
                                FontSize="14" />
                        <TextBlock Text="{x:Static loc:Strings.Stock_BalanceDetailsTitle}"
                                   Style="{StaticResource PageTitleStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="0" />
                    </DockPanel>

                    <!-- Variant name -->
                    <TextBlock Text="{Binding BalanceDetailVariantName}"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="{StaticResource FontSizeMedium}"
                               Margin="0,0,0,12" />

                    <!-- Per-warehouse breakdown grid -->
                    <DataGrid ItemsSource="{Binding BalanceDetailItems}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              Style="{StaticResource ThemedDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                              CellStyle="{StaticResource ThemedDataGridCellStyle}"
                              RowStyle="{StaticResource ThemedDataGridRowStyle}"
                              MaxHeight="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static loc:Strings.Field_WarehouseCode}"
                                                Binding="{Binding WarehouseCode}"
                                                Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FlowDirection" Value="LeftToRight" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{x:Static loc:Strings.Field_WarehouseName}"
                                                Binding="{Binding WarehouseName}"
                                                Width="*" />
                            <DataGridTextColumn Header="{x:Static loc:Strings.Field_Quantity}"
                                                Binding="{Binding Quantity, StringFormat=N0}"
                                                Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FlowDirection" Value="LeftToRight" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="{x:Static loc:Strings.Stock_OpenStockLedger}"
                                Command="{Binding NavigateToStockLedgerCommand}"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="16,8"
                                Margin="0,0,8,0" />
                        <Button Content="{x:Static loc:Strings.Action_Cancel}"
                                Command="{Binding CloseBalanceDetailsCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="16,8" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Busy overlay -->
        <controls:BusyOverlay Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConv}}" />
    </Grid>
</UserControl>
