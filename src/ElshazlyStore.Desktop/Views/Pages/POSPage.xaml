<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.POSPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:helpers="clr-namespace:ElshazlyStore.Desktop.Helpers"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:POSViewModel}"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded"
             FlowDirection="RightToLeft">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding LoadWarehousesCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{x:Static loc:Strings.Nav_SalesPos}"
                   Style="{StaticResource PageTitleStyle}"
                   HorizontalAlignment="Center"
                   Margin="24,16,24,8" />

        <controls:NotificationBar Grid.Row="1"
                                  Message="{Binding NotificationMessage}"
                                  NotificationType="{Binding NotificationType}"
                                  AutoDismissSeconds="4"
                                  Margin="24,0,24,6" />

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="24,0,24,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="1.2*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="{x:Static loc:Strings.Field_Warehouse}" Style="{StaticResource FormLabelStyle}" />
                            <ComboBox ItemsSource="{Binding Warehouses}"
                                      SelectedItem="{Binding SelectedWarehouse}"
                                      DisplayMemberPath="DisplayText"
                                      Style="{StaticResource ThemedComboBoxStyle}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="{x:Static loc:Strings.Sales_Customer}" Style="{StaticResource FormLabelStyle}" />

                            <Border Background="{DynamicResource SidebarBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8,6"
                                    Margin="0,0,0,6"
                                    Visibility="{Binding IsNamedCustomerSale, Converter={StaticResource BoolToVisConv}}">
                                <DockPanel>
                                    <Button Content="✕"
                                            Command="{Binding SetAnonymousSaleCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="6,2"
                                            DockPanel.Dock="Left"
                                            FontSize="12" />
                                    <TextBlock Text="{Binding SelectedCustomerDisplay}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0" />
                                </DockPanel>
                            </Border>

                            <Grid Visibility="{Binding IsNamedCustomerSale, Converter={StaticResource InverseBoolToVisConv}}">
                                <TextBox Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ThemedTextBoxStyle}" />
                                <Popup IsOpen="{Binding HasCustomerSearchResults}"
                                       PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                                       Placement="Bottom"
                                       MaxHeight="220"
                                       StaysOpen="False">
                                    <Border Background="{DynamicResource ContentBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            MinWidth="320">
                                        <ListBox ItemsSource="{Binding CustomerSearchResults}"
                                                 BorderThickness="0"
                                                 Background="Transparent">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8,6" Cursor="Hand">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                          CommandParameter="{Binding}" />
                                                        </Border.InputBindings>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontFamily="{StaticResource PrimaryFont}"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Code}" FlowDirection="LeftToRight"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                                           FontFamily="{StaticResource PrimaryFont}" />
                                                                <TextBlock Text=" — " Foreground="{DynamicResource SecondaryTextBrush}" />
                                                                <TextBlock Text="{Binding Phone}" FlowDirection="LeftToRight"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                                           FontFamily="{StaticResource PrimaryFont}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Popup>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="{x:Static loc:Strings.Sales_QuickAddCustomer}"
                                        Command="{Binding OpenCustomerQuickAddCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,6"
                                        Margin="0,0,8,0"
                                        Visibility="{Binding CanCreateCustomers, Converter={StaticResource BoolToVisConv}}" />
                                <Button Content="{x:Static loc:Strings.Sales_AnonymousAction}"
                                        Command="{Binding SetAnonymousSaleCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="10,6" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="{x:Static loc:Strings.Field_Date}" Style="{StaticResource FormLabelStyle}" />
                            <DatePicker SelectedDate="{Binding InvoiceDateUtc}"
                                        Style="{StaticResource ThemedDatePickerStyle}"
                                        FlowDirection="LeftToRight" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0">
                            <TextBlock Text="{x:Static loc:Strings.POS_SaleModeLabel}" Style="{StaticResource FormLabelStyle}" />
                            <Border Background="{DynamicResource SidebarBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,8">
                                <TextBlock Text="{Binding SaleModeIndicator}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           TextAlignment="Center" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="{x:Static loc:Strings.POS_BarcodeInputLabel}" Style="{StaticResource FormLabelStyle}" />
                            <TextBox x:Name="BarcodeInputBox"
                                     Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ThemedTextBoxStyle}"
                                     FlowDirection="LeftToRight">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                            <Button Content="{x:Static loc:Strings.POS_ScanAction}"
                                    Command="{Binding ScanBarcodeCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="16,8"
                                    IsEnabled="{Binding IsLookupBusy, Converter={StaticResource InvBool}}" />
                            <TextBlock Text="{x:Static loc:Strings.State_Loading}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding IsLookupBusy, Converter={StaticResource BoolToVisConv}}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2"
                           Text="{Binding FormError}"
                           Foreground="{DynamicResource ErrorBrush}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"
                           Visibility="{Binding FormError, Converter={StaticResource StringNotEmptyToVis}}" />

                <Border Grid.Row="3"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="{x:Static loc:Strings.Purchase_Lines}"
                                       Style="{StaticResource FormSectionTitleStyle}"
                                       Margin="0"
                                       DockPanel.Dock="Right" />
                            <Button Content="{x:Static loc:Strings.POS_ClearBasket}"
                                    Command="{Binding ClearBasketCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="10,6"
                                    DockPanel.Dock="Left" />
                            <Border />
                        </DockPanel>

                        <Grid Margin="0,4,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="74" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="114" />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static loc:Strings.Field_ProductName}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBlock Grid.Column="1" Text="{x:Static loc:Strings.Field_Quantity}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="2" Text="{x:Static loc:Strings.Sales_UnitPrice}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="3" Text="{x:Static loc:Strings.Sales_Discount}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="4" Text="{x:Static loc:Strings.Purchase_LineTotal}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="5" Text="{x:Static loc:Strings.POS_SplitLineLabel}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                        </Grid>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4" />

                        <ItemsControl ItemsSource="{Binding Lines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,6"
                                            Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="74" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="114" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                <TextBlock Text="{Binding ProductName}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="19"
                                                           FontWeight="Bold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding ProductName, Converter={StaticResource StringNotEmptyToVis}}" />
                                                <TextBlock Text="{Binding Barcode}"
                                                           FlowDirection="LeftToRight"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Margin="0,2,0,0"
                                                           Visibility="{Binding Barcode, Converter={StaticResource StringNotEmptyToVis}}" />
                                                <TextBlock Text="{Binding VariantDisplay}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,3,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding VariantDisplay, Converter={StaticResource StringNotEmptyToVis}}" />
                                            </StackPanel>

                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Quantity, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource CashierLineEditorTextBoxStyle}"
                                                     FlowDirection="LeftToRight"
                                                     Margin="4,0"
                                                     MinWidth="58"
                                                     helpers:NumericTextBoxBehavior.IsEnabled="True"
                                                     helpers:NumericTextBoxBehavior.FractionDigits="3"
                                                     helpers:NumericTextBoxBehavior.AutoScaleIntegerInput="False" />

                                            <TextBox Grid.Column="2"
                                                     Text="{Binding UnitPrice, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource CashierLineEditorTextBoxStyle}"
                                                     FlowDirection="LeftToRight"
                                                     Margin="4,0"
                                                     MinWidth="74"
                                                     helpers:NumericTextBoxBehavior.IsEnabled="True"
                                                     helpers:NumericTextBoxBehavior.FractionDigits="2"
                                                     helpers:NumericTextBoxBehavior.AutoScaleIntegerInput="True" />

                                            <TextBox Grid.Column="3"
                                                     Text="{Binding DiscountAmount, UpdateSourceTrigger=LostFocus}"
                                                     Style="{StaticResource CashierLineEditorTextBoxStyle}"
                                                     FlowDirection="LeftToRight"
                                                     Margin="4,0"
                                                     MinWidth="74"
                                                     helpers:NumericTextBoxBehavior.IsEnabled="True"
                                                     helpers:NumericTextBoxBehavior.FractionDigits="2"
                                                     helpers:NumericTextBoxBehavior.AutoScaleIntegerInput="True" />

                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding LineTotalDisplay}"
                                                       FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       FlowDirection="LeftToRight"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0" />

                                            <StackPanel Grid.Column="5"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding CanSplit, Converter={StaticResource BoolToVisConv}}">
                                                <Button Content="{x:Static loc:Strings.POS_SplitOneAction}"
                                                        Command="{Binding DataContext.SplitSingleUnitCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Padding="6,2"
                                                        FontSize="11"
                                                        Margin="0,0,4,0" />
                                                <Button Content="{x:Static loc:Strings.POS_SplitAllAction}"
                                                        Command="{Binding DataContext.SplitAllUnitsCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Padding="6,2"
                                                        FontSize="11" />
                                            </StackPanel>

                                            <Button Grid.Column="6"
                                                    Content="{x:Static loc:Strings.Action_RemoveLine}"
                                                    Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Padding="6,2"
                                                    Margin="4,0,0,0"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <controls:EmptyState Visibility="{Binding HasLines, Converter={StaticResource InverseBoolToVisConv}}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="4"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,12"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="1.8*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="{x:Static loc:Strings.POS_PaymentStateLabel}" Style="{StaticResource FormLabelStyle}" />
                            <Border Background="{DynamicResource SidebarBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding PaymentModeTitle}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="15"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <TextBlock Text="{Binding PaymentModeDescription}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="{x:Static loc:Strings.POS_CashModeSelectorLabel}"
                                       Style="{StaticResource SecondaryFieldLabelStyle}"
                                       Margin="0,10,0,6"
                                       Visibility="{Binding ShowCashCheckoutModeSelector, Converter={StaticResource BoolToVisConv}}" />
                            <ComboBox ItemsSource="{Binding CashCheckoutModes}"
                                      SelectedItem="{Binding SelectedCashCheckoutMode}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource ThemedComboBoxStyle}"
                                      Visibility="{Binding ShowCashCheckoutModeSelector, Converter={StaticResource BoolToVisConv}}" />

                            <TextBlock Text="{Binding PaymentPersistenceHint}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,10,0,0"
                                       TextWrapping="Wrap" />

                            <TextBlock Text="{x:Static loc:Strings.Payment_Method}"
                                       Style="{StaticResource SecondaryFieldLabelStyle}"
                                       Margin="0,10,0,6" />
                            <ComboBox ItemsSource="{Binding PaymentMethods}"
                                      SelectedItem="{Binding SelectedPaymentMethod}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource ThemedComboBoxStyle}" />

                            <TextBlock Text="{x:Static loc:Strings.Payment_WalletName}"
                                       Style="{StaticResource SecondaryFieldLabelStyle}"
                                       Margin="0,8,0,6"
                                       Visibility="{Binding ShowWalletNameField, Converter={StaticResource BoolToVisConv}}" />
                            <ComboBox ItemsSource="{Binding WalletProviders}"
                                      SelectedItem="{Binding SelectedWalletProvider}"
                                      DisplayMemberPath="DisplayName"
                                      Style="{StaticResource ThemedComboBoxStyle}"
                                      Visibility="{Binding ShowWalletNameField, Converter={StaticResource BoolToVisConv}}" />

                            <TextBlock Text="اسم البنك"
                                       Style="{StaticResource SecondaryFieldLabelStyle}"
                                       Margin="0,8,0,6"
                                       Visibility="{Binding ShowBankNameField, Converter={StaticResource BoolToVisConv}}" />
                            <TextBox Text="{Binding BankWalletName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SecondaryCompactTextBoxStyle}"
                                     FlowDirection="RightToLeft"
                                     Visibility="{Binding ShowBankNameField, Converter={StaticResource BoolToVisConv}}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="{x:Static loc:Strings.POS_ReferenceOptional}" Style="{StaticResource SecondaryFieldLabelStyle}" />
                            <TextBox Text="{Binding PaymentReference, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SecondaryCompactTextBoxStyle}"
                                     FlowDirection="LeftToRight" />

                            <TextBlock Text="{x:Static loc:Strings.POS_NotesOptional}"
                                       Style="{StaticResource SecondaryFieldLabelStyle}"
                                       Margin="0,8,0,6" />
                            <TextBox Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SecondaryCompactTextBoxStyle}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="56" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <Border Background="{DynamicResource CashierAccentBackgroundBrush}"
                                    BorderBrush="{DynamicResource CashierAccentBorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="10"
                                    Padding="18,16">
                                <StackPanel>
                                    <TextBlock Text="{x:Static loc:Strings.Sales_Total}"
                                               Style="{StaticResource SecondaryFieldLabelStyle}"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <TextBlock Text="{Binding InvoiceTotalDisplay}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="42"
                                               FontWeight="Bold"
                                               FlowDirection="LeftToRight"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <TextBlock Text="{Binding SaleModeIndicator}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{x:Static loc:Strings.POS_CheckoutShortcutHint}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,2,0,0" />

                                    <StackPanel Margin="0,14,0,0"
                                                Visibility="{Binding ShowTenderedAmountInput, Converter={StaticResource BoolToVisConv}}">
                                        <TextBlock Text="{Binding AmountEntryLabel}"
                                                   Style="{StaticResource SecondaryFieldLabelStyle}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <TextBox Text="{Binding TenderedAmountText, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource CashierAmountTextBoxStyle}"
                                                 FlowDirection="LeftToRight"
                                                 helpers:NumericTextBoxBehavior.IsEnabled="True"
                                                 helpers:NumericTextBoxBehavior.FractionDigits="2"
                                                 helpers:NumericTextBoxBehavior.AutoScaleIntegerInput="False" />

                                        <Border Background="{DynamicResource InputBackgroundBrush}"
                                                BorderBrush="{DynamicResource CashierAccentBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12,10"
                                                Margin="0,10,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="{Binding TenderOutcomeLabel}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding TenderOutcomeAmountDisplay}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           FlowDirection="LeftToRight"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Visibility="{Binding ShowTenderOutcomeAmount, Converter={StaticResource BoolToVisConv}}" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>

                                    <TextBlock Text="{Binding PaymentPersistenceHint}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,12,0,0"
                                               TextWrapping="Wrap" />

                                    <Button Content="{x:Static loc:Strings.POS_CompleteSaleAction}"
                                            Command="{Binding CompleteCheckoutCommand}"
                                            Style="{StaticResource AccentButtonStyle}"
                                            IsDefault="True"
                                            Padding="20,12"
                                            Margin="0,14,0,0"
                                            IsEnabled="{Binding IsSubmitting, Converter={StaticResource InvBool}}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

          <Grid Grid.RowSpan="4"
              Panel.ZIndex="20"
              Visibility="{Binding IsCustomerQuickAddOpen, Converter={StaticResource BoolToVisConv}}">
            <Border Background="#70000000" />
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0"
                    Margin="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                    <StackPanel Margin="24,20" MaxWidth="470">
                        <DockPanel Margin="0,0,0,16">
                            <Button Content="✕"
                                    Command="{Binding CloseCustomerQuickAddCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    DockPanel.Dock="Left"
                                    FontSize="14" />
                            <TextBlock Text="{x:Static loc:Strings.Sales_QuickAddCustomer}"
                                       Style="{StaticResource PageTitleStyle}"
                                       HorizontalAlignment="Center"
                                       Margin="0" />
                        </DockPanel>

                        <TextBlock Text="{x:Static loc:Strings.Field_Name}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding NewCustomerName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,12" />

                        <TextBlock Text="{x:Static loc:Strings.Field_Phone}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding NewCustomerPhone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,12"
                                 FlowDirection="LeftToRight" />

                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,10"
                                Margin="0,0,0,12"
                                Visibility="{Binding HasCustomerQuickAddSuggestions, Converter={StaticResource BoolToVisConv}}">
                            <StackPanel>
                                <TextBlock Text="{x:Static loc:Strings.Sales_ExistingCustomerHint}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap" />
                                <ItemsControl ItemsSource="{Binding CustomerQuickAddSuggestions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="0,0,0,1"
                                                    Padding="0,6">
                                                <DockPanel>
                                                    <Button Content="{x:Static loc:Strings.Sales_UseExistingCustomer}"
                                                            Command="{Binding DataContext.UseQuickAddSuggestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                            Padding="8,4"
                                                            DockPanel.Dock="Left" />
                                                    <StackPanel Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Code}" FlowDirection="LeftToRight"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       FontFamily="{StaticResource PrimaryFont}" />
                                                            <TextBlock Text=" — " Foreground="{DynamicResource SecondaryTextBrush}" />
                                                            <TextBlock Text="{Binding Phone}" FlowDirection="LeftToRight"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       FontFamily="{StaticResource PrimaryFont}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{Binding NewCustomerError}"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"
                                   Visibility="{Binding NewCustomerError, Converter={StaticResource StringNotEmptyToVis}}" />

                        <StackPanel Orientation="Horizontal">
                            <Button Content="{x:Static loc:Strings.Action_Save}"
                                    Command="{Binding SaveNewCustomerCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="24,8"
                                    Margin="0,0,8,0"
                                    IsEnabled="{Binding IsSavingCustomer, Converter={StaticResource InvBool}}" />
                            <Button Content="{x:Static loc:Strings.Action_Cancel}"
                                    Command="{Binding CloseCustomerQuickAddCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="24,8" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <controls:BusyOverlay Grid.RowSpan="4"
                              Panel.ZIndex="30"
                              Visibility="{Binding IsSubmittingOverlayVisible, Converter={StaticResource BoolToVisConv}}" />
    </Grid>
</UserControl>
