<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.SalesReturnsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SalesReturnsViewModel}"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <!-- ═══ Main list view ═══ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{x:Static loc:Strings.Nav_SalesReturns}"
                       Style="{StaticResource PageTitleStyle}"
                       HorizontalAlignment="Center"
                       Margin="24,16,24,8" />

            <!-- Notification Bar -->
            <controls:NotificationBar Grid.Row="1"
                                      Message="{Binding NotificationMessage}"
                                      NotificationType="{Binding NotificationType}"
                                      Margin="24,0,24,4" />

            <!-- Toolbar -->
            <DockPanel Grid.Row="2" Margin="24,0,24,8">
                <Button Content="{x:Static loc:Strings.SalesReturn_CreateNew}"
                        Command="{Binding OpenCreateCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Visibility="{Binding CanCreate, Converter={StaticResource BoolToVisConv}}" />
                <Button Content="{x:Static loc:Strings.Action_Refresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_Search}"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_Clear}"
                        Command="{Binding ClearSearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"
                         DockPanel.Dock="Right"
                         Margin="8,0,0,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Border />
            </DockPanel>

            <!-- DataGrid -->
            <DataGrid Grid.Row="3"
                      ItemsSource="{Binding Items}"
                      Style="{StaticResource ThemedDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      RowStyle="{StaticResource ThemedDataGridRowStyle}"
                      Margin="24,0"
                      Visibility="{Binding HasError, Converter={StaticResource InverseBoolToVisConv}}">
                <DataGrid.Columns>
                    <!-- رقم المرتجع -->
                    <DataGridTextColumn Header="{x:Static loc:Strings.SalesReturn_ReturnNumber}"
                                        Binding="{Binding DocumentNumber}"
                                        Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- العميل -->
                    <DataGridTextColumn Header="{x:Static loc:Strings.Sales_Customer}"
                                        Binding="{Binding CustomerNameDisplay}"
                                        Width="*" />

                    <!-- التاريخ -->
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Date}"
                                        Binding="{Binding CreatedAtUtc, StringFormat=yyyy-MM-dd}"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- رقم الفاتورة الأصلية -->
                    <DataGridTextColumn Header="{x:Static loc:Strings.SalesReturn_OriginalInvoice}"
                                        Binding="{Binding OriginalInvoiceNumber}"
                                        Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- المخزن -->
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Warehouse}"
                                        Binding="{Binding WarehouseName}"
                                        Width="120" />

                    <!-- الحالة -->
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Status}"
                                        Binding="{Binding StatusDisplay}"
                                        Width="90" />

                    <!-- الإجمالي -->
                    <DataGridTextColumn Header="{x:Static loc:Strings.Sales_Total}"
                                        Binding="{Binding Total, Converter={StaticResource SmartNumberConv}}"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <!-- إجراءات -->
                    <DataGridTemplateColumn Header="{x:Static loc:Strings.Field_Actions}" Width="330">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- تفاصيل — دائمًا -->
                                    <Button Content="{x:Static loc:Strings.Action_Details}"
                                            Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4" Margin="2,0" />

                                    <!-- تعديل — Draft فقط -->
                                    <Button Command="{Binding DataContext.OpenEditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanCreate, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Content" Value="{x:Static loc:Strings.Action_Edit}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Posted">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Voided">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- حذف — Draft فقط -->
                                    <Button Command="{Binding DataContext.DeleteReturnCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanCreate, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                                                <Setter Property="Content" Value="{x:Static loc:Strings.Action_Delete}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Posted">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Voided">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- ترحيل — Draft فقط (مخفي للمرحّل والملغي) -->
                                    <Button Command="{Binding DataContext.PostReturnCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanPost, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                                <Setter Property="Content" Value="{x:Static loc:Strings.Action_Post}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Posted">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Voided">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- طباعة — دائمًا -->
                                    <Button Content="{x:Static loc:Strings.Action_Print}"
                                            Command="{Binding DataContext.PrintSalesReturnCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4" Margin="2,0" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <controls:EmptyState Grid.Row="3"
                                 Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisConv}}" />
            <controls:ErrorDisplay Grid.Row="3"
                                   Message="{Binding ErrorMessage}"
                                   RetryCommand="{Binding RefreshCommand}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisConv}}" />

            <!-- Paging -->
            <DockPanel Grid.Row="4" Margin="24,8">
                <TextBlock Text="{Binding PagingInfo}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="{x:Static loc:Strings.Paging_First}" Command="{Binding FirstPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Next}" Command="{Binding NextPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Last}" Command="{Binding LastPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                </StackPanel>
                <Border />
            </DockPanel>
        </Grid>

        <!-- ═══ MODAL: Detail view ═══ -->
        <Grid Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVisConv}}">
            <Border Background="#80000000" />
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="720"
                    MaxHeight="580"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" DataContext="{Binding}">
                        <DockPanel Margin="0,0,0,16">
                            <Button Content="✕"
                                    Command="{Binding CloseDetailCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    DockPanel.Dock="Left"
                                    FontSize="14" />
                            <TextBlock Text="{x:Static loc:Strings.SalesReturn_DetailTitle}"
                                       Style="{StaticResource PageTitleStyle}"
                                       HorizontalAlignment="Center"
                                       Margin="0" />
                        </DockPanel>

                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.SalesReturn_ReturnNumber}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedReturn.DocumentNumber}" FlowDirection="LeftToRight"
                                           FontFamily="{StaticResource PrimaryFont}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Field_Status}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedReturn.StatusDisplay}"
                                           FontFamily="{StaticResource PrimaryFont}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.SalesReturn_OriginalInvoice}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedReturn.OriginalInvoiceNumber}" FlowDirection="LeftToRight"
                                           FontFamily="{StaticResource PrimaryFont}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Sales_Customer}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedReturn.CustomerNameDisplay}"
                                           FontFamily="{StaticResource PrimaryFont}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Field_Warehouse}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedReturn.WarehouseName}"
                                           FontFamily="{StaticResource PrimaryFont}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Sales_Total}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedReturn.Total, StringFormat=N2}" FlowDirection="LeftToRight"
                                           FontFamily="{StaticResource PrimaryFont}" FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Field_Date}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedReturn.CreatedAtUtc, StringFormat=yyyy-MM-dd HH:mm}" FlowDirection="LeftToRight"
                                           FontFamily="{StaticResource PrimaryFont}" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="{x:Static loc:Strings.Field_Notes}" Style="{StaticResource FormLabelStyle}" />
                        <TextBlock Text="{Binding SelectedReturn.Notes}" TextWrapping="Wrap"
                                   FontFamily="{StaticResource PrimaryFont}" Margin="0,0,0,12" />

                        <!-- Lines -->
                        <TextBlock Text="{x:Static loc:Strings.Purchase_Lines}" Style="{StaticResource FormLabelStyle}" Margin="0,8,0,4" />
                        <DataGrid ItemsSource="{Binding SelectedReturn.Lines}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Style="{StaticResource ThemedDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                                  CellStyle="{StaticResource ThemedDataGridCellStyle}"
                                  RowStyle="{StaticResource ThemedDataGridRowStyle}"
                                  MaxHeight="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Sku}"
                                                    Binding="{Binding VariantSku}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_ProductName}"
                                                    Binding="{Binding ProductName}" Width="*" />
                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Quantity}"
                                                    Binding="{Binding Quantity}" Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Sales_UnitPrice}"
                                                    Binding="{Binding UnitPrice, StringFormat=N2}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.PurchaseReturn_Reason}"
                                                    Binding="{Binding ReasonCodeName}" Width="110" />
                                <DataGridTextColumn Header="{x:Static loc:Strings.SalesReturn_Disposition}"
                                                    Binding="{Binding DispositionDisplay}" Width="110" />
                                <DataGridTextColumn Header="{x:Static loc:Strings.Purchase_LineTotal}"
                                                    Binding="{Binding LineTotal, StringFormat=N2}" Width="90">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
                            <Button Content="{x:Static loc:Strings.Action_Print}"
                                    Command="{Binding PrintSalesReturnCommand}"
                                    CommandParameter="{Binding SelectedReturn}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,8" Margin="4,0" />
                            <Button Content="{x:Static loc:Strings.Action_Post}"
                                    Command="{Binding PostReturnCommand}"
                                    CommandParameter="{Binding SelectedReturn}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="16,8" Margin="4,0"
                                    Visibility="{Binding CanPost, Converter={StaticResource BoolToVisConv}}" />
                            <Button Content="{x:Static loc:Strings.Action_Close}"
                                    Command="{Binding CloseDetailCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,8" Margin="4,0" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ MODAL: Create/Edit form ═══ -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConv}}">
            <Border Background="#80000000" />
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="820"
                    MaxHeight="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" MaxWidth="770">

                        <!-- Modal header -->
                        <DockPanel Margin="0,0,0,16">
                            <Button Content="✕"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    DockPanel.Dock="Left"
                                    FontSize="14" />
                            <TextBlock Text="{x:Static loc:Strings.SalesReturn_FormTitle}"
                                       Style="{StaticResource PageTitleStyle}"
                                       HorizontalAlignment="Center"
                                       Margin="0" />
                        </DockPanel>

                        <!-- ── Section: Original Invoice ── -->
                        <TextBlock Text="{x:Static loc:Strings.SalesReturn_SelectInvoice}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <Grid Margin="0,0,0,4">
                            <TextBox Text="{Binding InvoiceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ThemedTextBoxStyle}"
                                     IsReadOnly="{Binding IsEditMode}"
                                     FlowDirection="LeftToRight" />
                            <Popup IsOpen="{Binding HasInvoiceSearchResults}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                                   Placement="Bottom"
                                   MaxHeight="200"
                                   StaysOpen="False">
                                <Border Background="{DynamicResource ContentBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        MinWidth="300">
                                    <ListBox ItemsSource="{Binding InvoiceSearchResults}"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.SelectInvoiceCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                      CommandParameter="{Binding}" />
                                                    </Border.InputBindings>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding InvoiceNumber}"
                                                                   FlowDirection="LeftToRight"
                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text=" — " Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="{Binding CustomerNameDisplay}"
                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text=" — " Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="{Binding InvoiceDateUtc, StringFormat=yyyy-MM-dd}"
                                                                   FlowDirection="LeftToRight"
                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Invoice search hint / note -->
                        <TextBlock Text="{Binding InvoiceSearchNote}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,4"
                                   Visibility="{Binding InvoiceSearchNote, Converter={StaticResource StringNotEmptyToVis}}" />

                        <!-- Loading invoice indicator -->
                        <TextBlock Text="{x:Static loc:Strings.State_Loading}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,2,0,4"
                                   Visibility="{Binding IsLoadingInvoice, Converter={StaticResource BoolToVisConv}}" />

                        <!-- Invoice error (15-day rule or other) -->
                        <Border Background="{DynamicResource ErrorBackgroundBrush}"
                                BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="12,8"
                                Margin="0,0,0,8"
                                Visibility="{Binding InvoiceInfoError, Converter={StaticResource StringNotEmptyToVis}}">
                            <TextBlock Text="{Binding InvoiceInfoError}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <!-- ── Section: Header fields ── -->
                        <!-- Customer (read-only — derived from selected invoice or locked in edit mode) -->
                        <StackPanel Margin="0,4,0,12"
                                    Visibility="{Binding FormCustomerName, Converter={StaticResource StringNotEmptyToVis}}">
                            <TextBlock Text="{x:Static loc:Strings.Sales_Customer}"
                                       Style="{StaticResource FormLabelStyle}" />
                            <TextBox Text="{Binding FormCustomerName, Mode=OneWay}"
                                     Style="{StaticResource ThemedTextBoxStyle}"
                                     IsReadOnly="True" />
                        </StackPanel>

                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Warehouse -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{x:Static loc:Strings.Field_Warehouse}"
                                           Style="{StaticResource FormLabelStyle}" />
                                <ComboBox ItemsSource="{Binding Warehouses}"
                                          SelectedItem="{Binding SelectedWarehouse}"
                                          DisplayMemberPath="DisplayText"
                                          Style="{StaticResource ThemedComboBoxStyle}" />
                            </StackPanel>

                            <!-- Notes -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{x:Static loc:Strings.Field_Notes}"
                                           Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ThemedTextBoxStyle}"
                                         TextWrapping="Wrap" AcceptsReturn="False"
                                         MinHeight="36" />
                            </StackPanel>
                        </Grid>

                        <!-- ── Section: Lines grid ── -->
                        <TextBlock Text="{x:Static loc:Strings.Purchase_Lines}"
                                   Style="{StaticResource FormLabelStyle}" Margin="0,8,0,8" />

                        <!-- Hint when invoice not yet selected -->
                        <Border Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="12,8"
                                Margin="0,0,0,8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedOriginalInvoice}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{x:Static loc:Strings.SalesReturn_LinesGridHint}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <!-- No reason codes warning -->
                        <Border Margin="0,0,0,8"
                                Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="12,10"
                                Visibility="{Binding HasNoReasonCodes, Converter={StaticResource BoolToVisConv}}">
                            <TextBlock Text="{x:Static loc:Strings.ReasonCode_EmptyState}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <!-- Column headers for lines grid -->
                        <Grid Margin="0,0,0,2"
                              Visibility="{Binding HasInvoiceSelected, Converter={StaticResource BoolToVisConv}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static loc:Strings.Field_ProductName}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBlock Grid.Column="1" Text="{x:Static loc:Strings.SalesReturn_SoldQty}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="2" Text="{x:Static loc:Strings.SalesReturn_AvailableQty}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="3" Text="{x:Static loc:Strings.SalesReturn_ReturnQty}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="4" Text="{x:Static loc:Strings.Sales_UnitPrice}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="5" Text="{x:Static loc:Strings.PurchaseReturn_Reason}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="6" Text="{x:Static loc:Strings.SalesReturn_Disposition}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="7" Text="{x:Static loc:Strings.Purchase_LineTotal}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                        </Grid>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4"
                                Visibility="{Binding HasInvoiceSelected, Converter={StaticResource BoolToVisConv}}" />

                        <!-- Lines items -->
                        <ItemsControl ItemsSource="{Binding Lines}"
                                      Visibility="{Binding HasInvoiceSelected, Converter={StaticResource BoolToVisConv}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,6"
                                            Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="140" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="80" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Product display -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding VariantDisplay}"
                                                       FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding VariantDisplay}" />

                                            <!-- Sold qty (readonly) -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SoldQty, Converter={StaticResource SmartNumberConv}}"
                                                       FlowDirection="LeftToRight"
                                                       FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0" />

                                            <!-- Available qty (readonly) -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding AvailableQty, Converter={StaticResource SmartNumberConv}}"
                                                       FlowDirection="LeftToRight"
                                                       FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0" />

                                            <!-- Return qty (editable) -->
                                            <TextBox Grid.Column="3"
                                                     Text="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ThemedTextBoxStyle}"
                                                     FlowDirection="LeftToRight"
                                                     Margin="4,0"
                                                     MinWidth="55" />

                                            <!-- Unit Price (editable) -->
                                            <TextBox Grid.Column="4"
                                                     Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ThemedTextBoxStyle}"
                                                     FlowDirection="LeftToRight"
                                                     Margin="4,0"
                                                     MinWidth="65" />

                                            <!-- Reason code -->
                                            <ComboBox Grid.Column="5"
                                                      ItemsSource="{Binding DataContext.ReasonCodes, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      SelectedItem="{Binding SelectedReasonCode}"
                                                      DisplayMemberPath="DisplayText"
                                                      Style="{StaticResource ThemedComboBoxStyle}"
                                                      Margin="4,0" />

                                            <!-- Disposition (ReturnToStock / Quarantine only) -->
                                            <ComboBox Grid.Column="6"
                                                      ItemsSource="{Binding DataContext.SupportedDispositions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      SelectedValuePath="Value"
                                                      DisplayMemberPath="Display"
                                                      SelectedValue="{Binding DispositionType}"
                                                      Style="{StaticResource ThemedComboBoxStyle}"
                                                      Margin="4,0" />

                                            <!-- Line total (readonly) -->
                                            <TextBlock Grid.Column="7"
                                                       Text="{Binding LineTotal, StringFormat=N2}"
                                                       FlowDirection="LeftToRight"
                                                       FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Form error message -->
                        <Border Background="{DynamicResource ErrorBackgroundBrush}"
                                BorderBrush="{DynamicResource ErrorBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="12,8"
                                Margin="0,12,0,0"
                                Visibility="{Binding FormError, Converter={StaticResource StringNotEmptyToVis}}">
                            <TextBlock Text="{Binding FormError}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       TextWrapping="Wrap" />
                        </Border>

                        <!-- Save / Cancel -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                            <Button Content="{x:Static loc:Strings.Action_Save}"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="20,10"
                                    Margin="0,0,8,0"
                                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvBool}}" />
                            <Button Content="{x:Static loc:Strings.Action_Cancel}"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="20,10" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
