<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.StockBalancesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:StockBalancesViewModel}"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page title -->
        <TextBlock Grid.Row="0" Text="{x:Static loc:Strings.Stock_BalancesTitle}"
                   Style="{StaticResource PageTitleStyle}"
                   HorizontalAlignment="Center"
                   Margin="24,16,24,8" />

        <!-- Toolbar: Warehouse filter + Search -->
        <DockPanel Grid.Row="1" Margin="24,0,24,8">
            <!-- Warehouse ComboBox -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock Text="{x:Static loc:Strings.Field_Warehouse}"
                           Style="{StaticResource FormLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding Warehouses}"
                          SelectedItem="{Binding SelectedWarehouse}"
                          DisplayMemberPath="DisplayText"
                          Style="{StaticResource ThemedComboBoxStyle}"
                          MinWidth="160"
                          VerticalContentAlignment="Center"
                          FontFamily="{StaticResource PrimaryFont}"
                          FontSize="{StaticResource FontSizeNormal}" />
                <Button Content="{x:Static loc:Strings.Action_Search}"
                        Command="{Binding FilterByWarehouseCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        Margin="4,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_Clear}"
                        Command="{Binding ClearWarehouseFilterCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        Margin="4,0,0,0" />
            </StackPanel>

            <!-- Refresh -->
            <Button Content="{x:Static loc:Strings.Action_Refresh}"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="12,8"
                    DockPanel.Dock="Left"
                    Margin="8,0,0,0" />

            <!-- Search -->
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource SearchTextBoxStyle}"
                     DockPanel.Dock="Right"
                     Margin="8,0,0,0">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <Button Content="{x:Static loc:Strings.Action_Search}"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="12,8"
                    DockPanel.Dock="Right"
                    Margin="4,0,0,0" />
            <Border />
        </DockPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Items}"
                  Style="{StaticResource ThemedDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                  CellStyle="{StaticResource ThemedDataGridCellStyle}"
                  RowStyle="{StaticResource ThemedDataGridRowStyle}"
                  Margin="24,0"
                  Visibility="{Binding HasError, Converter={StaticResource InverseBoolToVisConv}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Sku}"
                                    Binding="{Binding Sku}"
                                    Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FlowDirection" Value="LeftToRight" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Barcode}"
                                    Binding="{Binding Barcode}"
                                    Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FlowDirection" Value="LeftToRight" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_ProductName}"
                                    Binding="{Binding ProductName}"
                                    Width="2*" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Quantity}"
                                    Binding="{Binding Quantity, StringFormat=N0}"
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FlowDirection" Value="LeftToRight" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Warehouse}"
                                    Binding="{Binding WarehouseName}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty / Error states -->
        <!-- Rich empty state: no movements exist at all (no search active) -->
        <StackPanel Grid.Row="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="0,40"
                    Visibility="{Binding IsEmptyNoSearch, Converter={StaticResource BoolToVisConv}}">
            <Path Data="M20,2 H4 C3,2 2,2.9 2,4 V7 C2,7.7 2.4,8.4 3,8.7 V20 C3,21.1 3.9,22 5,22 H19 C20.1,22 21,21.1 21,20 V8.7 C21.6,8.4 22,7.7 22,7 V4 C22,2.9 21,2 20,2 Z M14,14 H10 V12 H14 V14 Z M20,7 H4 V4 H20 V7 Z"
                  Fill="{DynamicResource DisabledTextBrush}"
                  Width="48" Height="48"
                  Stretch="Uniform"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,16" />
            <TextBlock Text="{x:Static loc:Strings.Stock_BalancesEmpty}"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="{StaticResource FontSizeMedium}"
                       Foreground="{DynamicResource DisabledTextBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="400"
                       Margin="0,0,0,16" />
            <Button Content="{x:Static loc:Strings.Stock_OpenMovements}"
                    Command="{Binding NavigateToMovementsCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="16,8"
                    HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Generic empty state: search returned no results -->
        <controls:EmptyState Grid.Row="2"
                             Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisConv}}">
            <controls:EmptyState.Style>
                <Style TargetType="UserControl">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsEmpty}" Value="True" />
                                <Condition Binding="{Binding IsEmptyNoSearch}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:EmptyState.Style>
        </controls:EmptyState>

        <controls:ErrorDisplay Grid.Row="2"
                               Message="{Binding ErrorMessage}"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisConv}}" />

        <!-- Paging -->
        <DockPanel Grid.Row="3" Margin="24,8">
            <TextBlock Text="{Binding PagingInfo}"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Right" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="{x:Static loc:Strings.Paging_First}" Command="{Binding FirstPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                <Button Content="{x:Static loc:Strings.Paging_Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                <Button Content="{x:Static loc:Strings.Paging_Next}" Command="{Binding NextPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                <Button Content="{x:Static loc:Strings.Paging_Last}" Command="{Binding LastPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
            </StackPanel>
            <Border />
        </DockPanel>

        <!-- Busy overlay -->
        <controls:BusyOverlay Grid.Row="0" Grid.RowSpan="4"
                              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConv}}" />
    </Grid>
</UserControl>
