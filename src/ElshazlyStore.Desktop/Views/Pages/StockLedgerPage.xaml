<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.StockLedgerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:StockLedgerViewModel}"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page title -->
        <TextBlock Grid.Row="0" Text="{x:Static loc:Strings.Stock_LedgerTitle}"
                   Style="{StaticResource PageTitleStyle}"
                   HorizontalAlignment="Center"
                   Margin="24,16,24,8" />

        <!-- Filters row 1: Variant picker + Warehouse -->
        <WrapPanel Grid.Row="1" Margin="24,0,24,8" Orientation="Horizontal">
            <!-- Variant picker -->
            <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                <TextBlock Text="{x:Static loc:Strings.Field_Variant}"
                           Style="{StaticResource FormLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />

                <!-- Selected variant display -->
                <Border Visibility="{Binding IsVariantSelected, Converter={StaticResource BoolToVisConv}}"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource SmallCornerRadius}"
                        Padding="8,4"
                        Margin="0,0,4,0">
                    <DockPanel>
                        <Button Content="✕"
                                Command="{Binding ClearVariantSelectionCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="4,2"
                                DockPanel.Dock="Left" />
                        <TextBlock Text="{Binding SelectedVariantName}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0" />
                    </DockPanel>
                </Border>

                <!-- Variant search -->
                <StackPanel Visibility="{Binding IsVariantSelected, Converter={StaticResource InverseBoolToVisConv}}"
                            Orientation="Horizontal">
                    <Grid>
                        <TextBox x:Name="LedgerVariantSearchBox"
                                 Text="{Binding VariantSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 MinWidth="200"
                                 VerticalContentAlignment="Center" />
                        <!-- Placeholder hint -->
                        <TextBlock Text="{x:Static loc:Strings.Stock_VariantSearchHint}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   Foreground="{DynamicResource DisabledTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding VariantSearchText}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Variant search results dropdown -->
                        <Popup IsOpen="{Binding HasVariantSearchResults}"
                               StaysOpen="False"
                               PlacementTarget="{Binding ElementName=LedgerVariantSearchBox}"
                               Placement="Bottom"
                               HorizontalOffset="0">
                            <Border Background="{DynamicResource ContentBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource SmallCornerRadius}"
                                    MaxHeight="280"
                                    MinWidth="300">
                                <ListBox ItemsSource="{Binding VariantSearchResults}"
                                         Background="{DynamicResource ContentBackgroundBrush}"
                                         BorderThickness="0"
                                         MaxHeight="270">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,6" Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.SelectVariantCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                  CommandParameter="{Binding}" />
                                                </Border.InputBindings>
                                                <DockPanel>
                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                                                        <TextBlock Text="{Binding ProductName}"
                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                   FontSize="{StaticResource FontSizeNormal}" />
                                                        <!-- Color / Size meta -->
                                                        <TextBlock FontFamily="{StaticResource PrimaryFont}"
                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   Margin="6,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding Color, Converter={StaticResource StringNotEmptyToVis}}">
                                                            <Run Text="(" /><Run Text="{Binding Color, Mode=OneWay}" /><Run Text=")" />
                                                        </TextBlock>
                                                        <TextBlock FontFamily="{StaticResource PrimaryFont}"
                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   Margin="4,0,0,0"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="{Binding Size, Converter={StaticResource StringNotEmptyToVis}}">
                                                            <Run Text="[" /><Run Text="{Binding Size, Mode=OneWay}" /><Run Text="]" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                        <TextBlock Text="{Binding Sku}"
                                                                   FlowDirection="LeftToRight"
                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="{Binding Barcode}"
                                                                   FlowDirection="LeftToRight"
                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   Margin="12,0,0,0"
                                                                   Visibility="{Binding Barcode, Converter={StaticResource StringNotEmptyToVis}}" />
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <!-- Warehouse -->
            <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                <TextBlock Text="{x:Static loc:Strings.Field_Warehouse}"
                           Style="{StaticResource FormLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding Warehouses}"
                          SelectedItem="{Binding SelectedWarehouse}"
                          DisplayMemberPath="DisplayText"
                          Style="{StaticResource ThemedComboBoxStyle}"
                          MinWidth="140"
                          VerticalContentAlignment="Center"
                          FontFamily="{StaticResource PrimaryFont}"
                          FontSize="{StaticResource FontSizeNormal}" />
            </StackPanel>

            <!-- Date range -->
            <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                <TextBlock Text="{x:Static loc:Strings.Field_DateFrom}"
                           Style="{StaticResource FormLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <DatePicker SelectedDate="{Binding DateFrom}"
                            Style="{StaticResource ThemedDatePickerStyle}"
                            MinWidth="120"
                            FontFamily="{StaticResource PrimaryFont}"
                            FlowDirection="LeftToRight" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,16,4">
                <TextBlock Text="{x:Static loc:Strings.Field_DateTo}"
                           Style="{StaticResource FormLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0" />
                <DatePicker SelectedDate="{Binding DateTo}"
                            Style="{StaticResource ThemedDatePickerStyle}"
                            MinWidth="120"
                            FontFamily="{StaticResource PrimaryFont}"
                            FlowDirection="LeftToRight" />
            </StackPanel>

            <!-- Apply / Clear -->
            <Button Content="{x:Static loc:Strings.Action_Search}"
                    Command="{Binding ApplyFiltersCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="12,8"
                    Margin="0,0,4,4" />
            <Button Content="{x:Static loc:Strings.Action_Clear}"
                    Command="{Binding ClearFiltersCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="12,8"
                    Margin="0,0,4,4" />
            <Button Content="{x:Static loc:Strings.Action_Refresh}"
                    Command="{Binding RefreshCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Padding="12,8"
                    Margin="0,0,0,4" />
        </WrapPanel>

        <!-- Hint panel: shown when filters haven't been applied yet -->
        <StackPanel Grid.Row="3"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Margin="0,40"
                    Visibility="{Binding FiltersApplied, Converter={StaticResource InverseBoolToVisConv}}">
            <Path Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z"
                  Fill="{DynamicResource DisabledTextBrush}"
                  Width="48" Height="48"
                  Stretch="Uniform"
                  HorizontalAlignment="Center"
                  Margin="0,0,0,16" />
            <TextBlock Text="{x:Static loc:Strings.Stock_LedgerHintAllFilters}"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="{StaticResource FontSizeMedium}"
                       Foreground="{DynamicResource DisabledTextBrush}"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap"
                       MaxWidth="400" />
        </StackPanel>

        <!-- DataGrid (only after filters applied) -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Items}"
                  Style="{StaticResource ThemedDataGridStyle}"
                  ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                  CellStyle="{StaticResource ThemedDataGridCellStyle}"
                  RowStyle="{StaticResource ThemedDataGridRowStyle}"
                  Margin="24,0"
                  Visibility="{Binding FiltersApplied, Converter={StaticResource BoolToVisConv}}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Date}"
                                    Binding="{Binding PostedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                    Width="150">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FlowDirection" Value="LeftToRight" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_ProductVariantName}"
                                    Binding="{Binding ProductVariantName}"
                                    Width="180"
                                    Visibility="{Binding DataContext.ShowProductColumn, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_MovementType}"
                                    Binding="{Binding TypeDisplay}"
                                    Width="120" />
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Reference}"
                                    Binding="{Binding Reference}"
                                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FlowDirection" Value="LeftToRight" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Sku}"
                                    Binding="{Binding Sku}"
                                    Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FlowDirection" Value="LeftToRight" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_InQty}"
                                    Binding="{Binding InQuantity, StringFormat=N0}"
                                    Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FlowDirection" Value="LeftToRight" />
                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_OutQty}"
                                    Binding="{Binding OutQuantity, StringFormat=N0}"
                                    Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FlowDirection" Value="LeftToRight" />
                            <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_WarehouseCode}"
                                    Binding="{Binding WarehouseCode}"
                                    Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FlowDirection" Value="LeftToRight" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{x:Static loc:Strings.Field_WarehouseName}"
                                    Binding="{Binding WarehouseName}"
                                    Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty / Error states (only when filters applied) -->
        <controls:EmptyState Grid.Row="3">
            <controls:EmptyState.Style>
                <Style TargetType="UserControl">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding FiltersApplied}" Value="True" />
                                <Condition Binding="{Binding IsEmpty}" Value="True" />
                                <Condition Binding="{Binding HasError}" Value="False" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible" />
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </controls:EmptyState.Style>
        </controls:EmptyState>
        <controls:ErrorDisplay Grid.Row="3"
                               Message="{Binding ErrorMessage}"
                               Visibility="{Binding HasError, Converter={StaticResource BoolToVisConv}}" />

        <!-- Paging -->
        <DockPanel Grid.Row="4" Margin="24,8">
            <TextBlock Text="{Binding PagingInfo}"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="{StaticResource FontSizeSmall}"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Right" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button Content="{x:Static loc:Strings.Paging_First}" Command="{Binding FirstPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                <Button Content="{x:Static loc:Strings.Paging_Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                <Button Content="{x:Static loc:Strings.Paging_Next}" Command="{Binding NextPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                <Button Content="{x:Static loc:Strings.Paging_Last}" Command="{Binding LastPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
            </StackPanel>
            <Border />
        </DockPanel>

        <!-- Busy overlay -->
        <controls:BusyOverlay Grid.Row="0" Grid.RowSpan="5"
                              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConv}}" />
    </Grid>
</UserControl>
