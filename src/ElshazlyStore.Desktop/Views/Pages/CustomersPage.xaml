<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.CustomersPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:CustomersViewModel}"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}" />
    </UserControl.InputBindings>

    <Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Main list view                                       -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ══ Page header ══ -->
            <Border Grid.Row="0" Padding="28,18,28,10">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static loc:Strings.Nav_Customers}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Text="إدارة بيانات العملاء وتفاصيلهم"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ══ NotificationBar ══ -->
            <controls:NotificationBar Grid.Row="1"
                                      Message="{Binding NotificationMessage}"
                                      NotificationType="{Binding NotificationType}"
                                      Margin="24,0,24,4" />

            <!-- ══ Toolbar ══ -->
            <DockPanel Grid.Row="2" Margin="24,0,24,10">
                <Button Content="{x:Static loc:Strings.Action_Create}"
                        Command="{Binding OpenCreateCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="14,9"
                        DockPanel.Dock="Left"
                        Visibility="{Binding CanWrite, Converter={StaticResource BoolToVisConv}}" />
                <Button Content="{x:Static loc:Strings.Action_Refresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,9"
                        DockPanel.Dock="Left"
                        Margin="6,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_Clear}"
                        Command="{Binding ClearSearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,9"
                        DockPanel.Dock="Right"
                        Margin="0,0,6,0" />
                <Button Content="{x:Static loc:Strings.Action_Search}"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="10,9"
                        DockPanel.Dock="Right"
                        Margin="0,0,4,0" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"
                         DockPanel.Dock="Right"
                         MinWidth="260"
                         MaxWidth="380"
                         Margin="0,0,6,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Border />
            </DockPanel>

            <!-- ══ DataGrid card ══ -->
            <Border Grid.Row="3"
                    Margin="24,0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Background="{DynamicResource CardBackgroundBrush}"
                    Visibility="{Binding HasError, Converter={StaticResource InverseBoolToVisConv}}">
                <DataGrid ItemsSource="{Binding Items}"
                          Style="{StaticResource ThemedDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource ThemedDataGridCellStyle}"
                          RowStyle="{StaticResource ThemedDataGridRowStyle}"
                          BorderThickness="0"
                          Margin="0">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="{x:Static loc:Strings.Field_CustomerCode}"
                                            Binding="{Binding CustomerCode}"
                                            Width="130" />

                        <DataGridTextColumn Header="{x:Static loc:Strings.Field_Name}"
                                            Binding="{Binding Name}"
                                            Width="2*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{x:Static loc:Strings.Field_Phone}"
                                            Binding="{Binding Phone}"
                                            Width="*" />

                        <!-- Status column: colored badge -->
                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Field_Status}" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <!-- Active badge -->
                                        <Border CornerRadius="4"
                                                Padding="8,3"
                                                Margin="4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="#1640A02B"
                                                BorderBrush="#40A02B"
                                                BorderThickness="1"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVisConv}}">
                                            <TextBlock Text="نشط"
                                                       Foreground="#40A02B"
                                                       FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                        <!-- Inactive badge -->
                                        <Border CornerRadius="4"
                                                Padding="8,3"
                                                Margin="4"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="#16D20F39"
                                                BorderBrush="#D20F39"
                                                BorderThickness="1"
                                                Visibility="{Binding IsActive, Converter={StaticResource InverseBoolToVisConv}}">
                                            <TextBlock Text="غير نشط"
                                                       Foreground="#D20F39"
                                                       FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- Actions column -->
                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Field_Actions}" Width="440">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <!-- Details: always visible -->
                                        <Button Content="{x:Static loc:Strings.Action_Details}"
                                                Command="{Binding DataContext.OpenDetailsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="8,4" Margin="2,0" />
                                        <!-- CAFS-1-R1: Open attachments folder -->
                                        <Button Content="{x:Static loc:Strings.Customers_OpenFolder}"
                                                Command="{Binding DataContext.OpenAttachmentsFolderCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="8,4" Margin="2,0"
                                                ToolTip="{x:Static loc:Strings.Customers_OpenFolderTooltip}" />
                                        <!-- Payments: visible when user can view payments -->
                                        <Button Content="{x:Static loc:Strings.Customer_ViewPayments}"
                                                Command="{Binding DataContext.OpenCustomerPaymentsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="8,4" Margin="2,0"
                                                Visibility="{Binding DataContext.CanViewPayments, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}" />
                                        <!-- Edit: only if CanWrite -->
                                        <Button Content="{x:Static loc:Strings.Action_Edit}"
                                                Command="{Binding DataContext.OpenEditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="8,4" Margin="2,0"
                                                Visibility="{Binding DataContext.CanWrite, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}" />
                                        <!-- Deactivate: when active and CanWrite -->
                                        <Button Content="{x:Static loc:Strings.Action_Deactivate}"
                                                Command="{Binding DataContext.DeactivateCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Padding="8,4" Margin="2,0"
                                                Visibility="{Binding IsActive, Converter={StaticResource BoolToVisConv}}" />
                                        <!-- Reactivate: when inactive and CanWrite -->
                                        <Button Content="{x:Static loc:Strings.Action_Reactivate}"
                                                Command="{Binding DataContext.ReactivateCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="8,4" Margin="2,0"
                                                Visibility="{Binding IsActive, Converter={StaticResource InverseBoolToVisConv}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Empty / Error states -->
            <controls:EmptyState Grid.Row="3"
                                 Margin="24,0"
                                 Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisConv}}" />
            <controls:ErrorDisplay Grid.Row="3"
                                   Margin="24,0"
                                   Message="{Binding ErrorMessage}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisConv}}" />

            <!-- ══ Paging ══ -->
            <DockPanel Grid.Row="4" Margin="24,8,24,12">
                <TextBlock Text="{Binding PagingInfo}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="{x:Static loc:Strings.Paging_First}"    Command="{Binding FirstPageCommand}"    Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Next}"     Command="{Binding NextPageCommand}"     Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Last}"     Command="{Binding LastPageCommand}"     Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                </StackPanel>
                <Border />
            </DockPanel>

        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- MODAL: Create / Edit Customer                        -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConv}}">
            <!-- Dim backdrop -->
            <Border Background="#88000000" />
            <!-- Modal card -->
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    MaxWidth="600"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" Opacity="0.22" ShadowDepth="6" Direction="270" />
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="680">
                    <StackPanel Margin="28,24,28,24" MaxWidth="540">

                        <!-- Modal header -->
                        <DockPanel Margin="0,0,0,18">
                            <Button Content="✕"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    FontSize="14"
                                    DockPanel.Dock="Left" />
                            <TextBlock Text="{Binding FormTitle}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Section: Basic info -->
                        <TextBlock Text="{x:Static loc:Strings.Customers_BasicInfo}"
                                   Style="{StaticResource FormSectionTitleStyle}"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="{x:Static loc:Strings.Field_Name}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14" />

                        <TextBlock Text="{x:Static loc:Strings.Field_Code}"
                                   Style="{StaticResource FormLabelStyle}"
                                   Visibility="{Binding IsCodeReadOnly, Converter={StaticResource BoolToVisConv}}" />
                        <TextBox Text="{Binding FormCode, Mode=OneWay}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,4"
                                 FlowDirection="LeftToRight"
                                 IsReadOnly="True"
                                 Visibility="{Binding IsCodeReadOnly, Converter={StaticResource BoolToVisConv}}" />
                        <TextBlock Text="الكود يُولَّد تلقائيًا ولا يمكن تعديله"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,14"
                                   Visibility="{Binding IsCodeReadOnly, Converter={StaticResource BoolToVisConv}}" />

                        <!-- Divider -->
                        <Rectangle Height="1"
                                   Fill="{DynamicResource BorderBrush}"
                                   Margin="0,2,0,16" />

                        <!-- Section: Contact info -->
                        <TextBlock Text="{x:Static loc:Strings.Customers_ContactInfo}"
                                   Style="{StaticResource FormSectionTitleStyle}"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="{x:Static loc:Strings.Field_Phone}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormPhone, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 FlowDirection="LeftToRight" />

                        <TextBlock Text="{x:Static loc:Strings.Field_Phone2}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormPhone2, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 FlowDirection="LeftToRight" />

                        <!-- Divider -->
                        <Rectangle Height="1"
                                   Fill="{DynamicResource BorderBrush}"
                                   Margin="0,2,0,16" />

                        <!-- Section: Notes -->
                        <TextBlock Text="{x:Static loc:Strings.Field_Notes}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="72" />

                        <!-- Divider -->
                        <Rectangle Height="1"
                                   Fill="{DynamicResource BorderBrush}"
                                   Margin="0,2,0,16" />

                        <!-- Section: Digital payment info (CP-3A) -->
                        <TextBlock Text="{x:Static loc:Strings.Customers_DigitalPayment}"
                                   Style="{StaticResource FormSectionTitleStyle}"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="{x:Static loc:Strings.Field_WhatsApp}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormWhatsApp, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 FlowDirection="LeftToRight" />

                        <TextBlock Text="{x:Static loc:Strings.Field_WalletNumber}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormWalletNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 FlowDirection="LeftToRight" />

                        <TextBlock Text="{x:Static loc:Strings.Field_InstaPayId}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormInstaPayId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 FlowDirection="LeftToRight" />

                        <!-- Divider -->
                        <Rectangle Height="1"
                                   Fill="{DynamicResource BorderBrush}"
                                   Margin="0,2,0,16" />

                        <!-- Section: Commercial / Credit info (CP-3A) -->
                        <TextBlock Text="{x:Static loc:Strings.Customers_CommercialInfo}"
                                   Style="{StaticResource FormSectionTitleStyle}"
                                   Margin="0,0,0,10" />

                        <TextBlock Text="{x:Static loc:Strings.Field_CommercialName}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormCommercialName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14" />

                        <TextBlock Text="{x:Static loc:Strings.Field_CommercialAddress}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormCommercialAddress, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="48" />

                        <TextBlock Text="{x:Static loc:Strings.Field_NationalIdNumber}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormNationalIdNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 FlowDirection="LeftToRight" />

                        <!-- Form error block -->
                        <Border Visibility="{Binding FormError, Converter={StaticResource StringNotEmptyToVis}}"
                                Background="{DynamicResource ErrorBrush}"
                                Opacity="0.95"
                                CornerRadius="6"
                                Margin="0,0,0,14">
                            <Border.OpacityMask>
                                <SolidColorBrush Color="White" Opacity="0.13" />
                            </Border.OpacityMask>
                            <TextBlock Text="{Binding FormError}"
                                       Foreground="White"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       TextWrapping="Wrap"
                                       Margin="12,8" />
                        </Border>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Command="{Binding SaveCommand}"
                                    Padding="28,10"
                                    Margin="0,0,10,0"
                                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvBool}}">
                                <Button.Content>
                                    <TextBlock FontFamily="{StaticResource PrimaryFont}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{x:Static loc:Strings.Action_Save}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                                        <Setter Property="Text" Value="جاري الحفظ…" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button.Content>
                            </Button>
                            <Button Content="{x:Static loc:Strings.Action_Cancel}"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="24,10" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- MODAL: Customer Details (CP-3A upgraded)             -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Grid Visibility="{Binding IsViewingDetails, Converter={StaticResource BoolToVisConv}}">
            <!-- Dim backdrop -->
            <Border Background="#88000000" />
            <!-- Modal card -->
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    MaxWidth="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" Opacity="0.22" ShadowDepth="6" Direction="270" />
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="680">
                    <StackPanel Margin="28,24,28,24" MaxWidth="500">

                        <!-- Header row -->
                        <DockPanel Margin="0,0,0,16">
                            <Button Content="✕"
                                    Command="{Binding CloseDetailsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    FontSize="14"
                                    DockPanel.Dock="Left" />
                            <TextBlock Text="{x:Static loc:Strings.Customers_DetailTitle}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Customer identity card -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,14"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <!-- Name -->
                                <TextBlock Text="{Binding DetailCustomer.Name}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6" />
                                <!-- Code + Status row -->
                                <DockPanel>
                                    <!-- Status badges -->
                                    <Border DockPanel.Dock="Left"
                                            CornerRadius="4"
                                            Padding="7,3"
                                            Background="#1640A02B"
                                            BorderBrush="#40A02B"
                                            BorderThickness="1"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding DetailCustomer.IsActive, Converter={StaticResource BoolToVisConv}}">
                                        <TextBlock Text="نشط"
                                                   Foreground="#40A02B"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <Border DockPanel.Dock="Left"
                                            CornerRadius="4"
                                            Padding="7,3"
                                            Background="#16D20F39"
                                            BorderBrush="#D20F39"
                                            BorderThickness="1"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding DetailCustomer.IsActive, Converter={StaticResource InverseBoolToVisConv}}">
                                        <TextBlock Text="غير نشط"
                                                   Foreground="#D20F39"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                    <!-- Code -->
                                    <TextBlock Text="{Binding DetailCustomer.CustomerCode}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0"
                                               FlowDirection="LeftToRight" />
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Contact info section -->
                        <TextBlock Text="{x:Static loc:Strings.Customers_ContactInfo}"
                                   Style="{StaticResource FormSectionTitleStyle}"
                                   Margin="0,0,0,10" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="{x:Static loc:Strings.Field_Phone}"
                                       Style="{StaticResource FormLabelStyle}"
                                       Margin="0,0,12,8" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding DetailCustomer.Phone, Mode=OneWay}"
                                     FontFamily="{StaticResource PrimaryFont}"
                                     FontSize="13"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     FlowDirection="LeftToRight"
                                     TextAlignment="Right"
                                     Margin="0,0,0,8"
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     IsTabStop="False" />
                            <TextBlock Grid.Row="1" Grid.Column="0"
                                       Text="{x:Static loc:Strings.Field_Phone2}"
                                       Style="{StaticResource FormLabelStyle}"
                                       Margin="0,0,12,8" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding DetailCustomer.Phone2, Mode=OneWay}"
                                     FontFamily="{StaticResource PrimaryFont}"
                                     FontSize="13"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     FlowDirection="LeftToRight"
                                     TextAlignment="Right"
                                     Margin="0,0,0,8"
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     IsTabStop="False" />
                            <TextBlock Grid.Row="2" Grid.Column="0"
                                       Text="{x:Static loc:Strings.Field_WhatsApp}"
                                       Style="{StaticResource FormLabelStyle}"
                                       Margin="0,0,12,0"
                                       Visibility="{Binding DetailCustomer.WhatsApp, Converter={StaticResource StringNotEmptyToVis}}" />
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding DetailCustomer.WhatsApp, Mode=OneWay}"
                                     FontFamily="{StaticResource PrimaryFont}"
                                     FontSize="13"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     FlowDirection="LeftToRight"
                                     TextAlignment="Right"
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     IsTabStop="False"
                                     Visibility="{Binding DetailCustomer.WhatsApp, Converter={StaticResource StringNotEmptyToVis}}" />
                        </Grid>

                        <!-- Digital payment section (only if any field has value) -->
                        <StackPanel Margin="0,10,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DetailCustomer.WalletNumber, Converter={StaticResource StringNotEmptyToVis}}" Value="Visible">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DetailCustomer.InstaPayId, Converter={StaticResource StringNotEmptyToVis}}" Value="Visible">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Rectangle Height="1"
                                       Fill="{DynamicResource BorderBrush}"
                                       Margin="0,0,0,14" />
                            <TextBlock Text="{x:Static loc:Strings.Customers_DigitalPayment}"
                                       Style="{StaticResource FormSectionTitleStyle}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{x:Static loc:Strings.Field_WalletNumber}"
                                           Style="{StaticResource FormLabelStyle}"
                                           Margin="0,0,12,8"
                                           Visibility="{Binding DetailCustomer.WalletNumber, Converter={StaticResource StringNotEmptyToVis}}" />
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Text="{Binding DetailCustomer.WalletNumber, Mode=OneWay}"
                                         FontFamily="{StaticResource PrimaryFont}"
                                         FontSize="13"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         FlowDirection="LeftToRight"
                                         TextAlignment="Right"
                                         Margin="0,0,0,8"
                                         IsReadOnly="True"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         IsTabStop="False"
                                         Visibility="{Binding DetailCustomer.WalletNumber, Converter={StaticResource StringNotEmptyToVis}}" />
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{x:Static loc:Strings.Field_InstaPayId}"
                                           Style="{StaticResource FormLabelStyle}"
                                           Margin="0,0,12,0"
                                           Visibility="{Binding DetailCustomer.InstaPayId, Converter={StaticResource StringNotEmptyToVis}}" />
                                <TextBox Grid.Row="1" Grid.Column="1"
                                         Text="{Binding DetailCustomer.InstaPayId, Mode=OneWay}"
                                         FontFamily="{StaticResource PrimaryFont}"
                                         FontSize="13"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         FlowDirection="LeftToRight"
                                         TextAlignment="Right"
                                         IsReadOnly="True"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         IsTabStop="False"
                                         Visibility="{Binding DetailCustomer.InstaPayId, Converter={StaticResource StringNotEmptyToVis}}" />
                            </Grid>
                        </StackPanel>

                        <!-- Commercial info section (only if any field has value) -->
                        <StackPanel Margin="0,10,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DetailCustomer.CommercialName, Converter={StaticResource StringNotEmptyToVis}}" Value="Visible">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DetailCustomer.CommercialAddress, Converter={StaticResource StringNotEmptyToVis}}" Value="Visible">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DetailCustomer.NationalIdNumber, Converter={StaticResource StringNotEmptyToVis}}" Value="Visible">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Rectangle Height="1"
                                       Fill="{DynamicResource BorderBrush}"
                                       Margin="0,0,0,14" />
                            <TextBlock Text="{x:Static loc:Strings.Customers_CommercialInfo}"
                                       Style="{StaticResource FormSectionTitleStyle}"
                                       Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{x:Static loc:Strings.Field_CommercialName}"
                                           Style="{StaticResource FormLabelStyle}"
                                           Margin="0,0,12,8"
                                           Visibility="{Binding DetailCustomer.CommercialName, Converter={StaticResource StringNotEmptyToVis}}" />
                                <TextBlock Grid.Row="0" Grid.Column="1"
                                           Text="{Binding DetailCustomer.CommercialName}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding DetailCustomer.CommercialName, Converter={StaticResource StringNotEmptyToVis}}" />
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{x:Static loc:Strings.Field_CommercialAddress}"
                                           Style="{StaticResource FormLabelStyle}"
                                           Margin="0,0,12,8"
                                           Visibility="{Binding DetailCustomer.CommercialAddress, Converter={StaticResource StringNotEmptyToVis}}" />
                                <TextBlock Grid.Row="1" Grid.Column="1"
                                           Text="{Binding DetailCustomer.CommercialAddress}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="13"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding DetailCustomer.CommercialAddress, Converter={StaticResource StringNotEmptyToVis}}" />
                                <TextBlock Grid.Row="2" Grid.Column="0"
                                           Text="{x:Static loc:Strings.Field_NationalIdNumber}"
                                           Style="{StaticResource FormLabelStyle}"
                                           Margin="0,0,12,0"
                                           Visibility="{Binding DetailCustomer.NationalIdNumber, Converter={StaticResource StringNotEmptyToVis}}" />
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding DetailCustomer.NationalIdNumber, Mode=OneWay}"
                                         FontFamily="{StaticResource PrimaryFont}"
                                         FontSize="13"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         FlowDirection="LeftToRight"
                                         TextAlignment="Right"
                                         IsReadOnly="True"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         IsTabStop="False"
                                         Visibility="{Binding DetailCustomer.NationalIdNumber, Converter={StaticResource StringNotEmptyToVis}}" />
                            </Grid>
                        </StackPanel>

                        <!-- Notes section (only if non-empty) -->
                        <StackPanel Visibility="{Binding DetailCustomer.Notes, Converter={StaticResource StringNotEmptyToVis}}"
                                    Margin="0,10,0,0">
                            <Rectangle Height="1"
                                       Fill="{DynamicResource BorderBrush}"
                                       Margin="0,0,0,14" />
                            <TextBlock Text="{x:Static loc:Strings.Field_Notes}"
                                       Style="{StaticResource FormSectionTitleStyle}"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{Binding DetailCustomer.Notes}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="13"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Attachments section (CP-3A) -->
                        <Rectangle Height="1"
                                   Fill="{DynamicResource BorderBrush}"
                                   Margin="0,14,0,10" />
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="{x:Static loc:Strings.Customers_Attachments}"
                                       Style="{StaticResource FormSectionTitleStyle}"
                                       DockPanel.Dock="Right"
                                       VerticalAlignment="Center" />
                            <!-- Upload buttons -->
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left"
                                        Visibility="{Binding CanWrite, Converter={StaticResource BoolToVisConv}}">
                                <Button Content="{x:Static loc:Strings.Customers_UploadNationalId}"
                                        Command="{Binding UploadAttachmentCommand}"
                                        CommandParameter="national_id"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,4" Margin="0,0,4,0"
                                        FontSize="11"
                                        IsEnabled="{Binding IsUploadingAttachment, Converter={StaticResource InvBool}}" />
                                <Button Content="{x:Static loc:Strings.Customers_UploadContract}"
                                        Command="{Binding UploadAttachmentCommand}"
                                        CommandParameter="contract"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,4" Margin="0,0,4,0"
                                        FontSize="11"
                                        IsEnabled="{Binding IsUploadingAttachment, Converter={StaticResource InvBool}}" />
                                <Button Content="{x:Static loc:Strings.Customers_UploadOther}"
                                        Command="{Binding UploadAttachmentCommand}"
                                        CommandParameter="other"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,4"
                                        FontSize="11"
                                        IsEnabled="{Binding IsUploadingAttachment, Converter={StaticResource InvBool}}" />
                            </StackPanel>
                        </DockPanel>

                        <!-- Attachment list -->
                        <ItemsControl ItemsSource="{Binding DetailAttachments}" Margin="0,0,0,6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,8"
                                            Margin="0,0,0,6">
                                        <DockPanel>
                                            <!-- Actions -->
                                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                                                <Button Content="{x:Static loc:Strings.Customers_OpenAttachment}"
                                                        Command="{Binding DataContext.OpenAttachmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource AccentButtonStyle}"
                                                        Padding="8,3" Margin="0,0,4,0"
                                                        FontSize="11"
                                                        ToolTip="{x:Static loc:Strings.Customers_OpenAttachment}" />
                                                <Button Content="⬇"
                                                        Command="{Binding DataContext.DownloadAttachmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Padding="6,3" Margin="0,0,4,0"
                                                        FontSize="12"
                                                        ToolTip="{x:Static loc:Strings.Customers_DownloadAttachment}" />
                                                <Button Content="✕"
                                                        Command="{Binding DataContext.DeleteAttachmentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DangerButtonStyle}"
                                                        Padding="6,3"
                                                        FontSize="11"
                                                        Visibility="{Binding DataContext.CanWrite, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BoolToVisConv}}" />
                                            </StackPanel>
                                            <!-- File info -->
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FileName}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource SecondaryTextBrush}">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} — {1:yyyy/MM/dd}">
                                                            <Binding Path="Category" />
                                                            <Binding Path="CreatedAtUtc" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- No attachments message -->
                        <TextBlock Text="{x:Static loc:Strings.Customers_NoAttachments}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DetailAttachments.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Meta: created date -->
                        <Rectangle Height="1"
                                   Fill="{DynamicResource BorderBrush}"
                                   Margin="0,4,0,10" />
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{x:Static loc:Strings.Field_CreatedAt}"
                                       Style="{StaticResource FormLabelStyle}"
                                       Margin="0,0,12,0" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding DetailCustomerCreatedDateDisplay}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="13"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FlowDirection="LeftToRight"
                                       TextAlignment="Right" />
                        </Grid>

                        <!-- Payments section — navigates to customer payments page (CP-2) -->
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,12"
                                Margin="0,14,0,0"
                                Visibility="{Binding CanViewPayments, Converter={StaticResource BoolToVisConv}}">
                            <DockPanel>
                                <Button Content="{x:Static loc:Strings.Customer_ViewPayments}"
                                        Command="{Binding OpenCustomerPaymentsCommand}"
                                        CommandParameter="{Binding DetailCustomer}"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="14,8"
                                        DockPanel.Dock="Left"
                                        VerticalAlignment="Center" />
                                <TextBlock Text="{x:Static loc:Strings.CustomerPayments_ContextSubtitle}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           VerticalAlignment="Center"
                                           Margin="12,0,0,0" />
                            </DockPanel>
                        </Border>

                        <!-- Detail action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                            <Button Content="{x:Static loc:Strings.Action_Edit}"
                                    Command="{Binding EditFromDetailsCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="24,10"
                                    Margin="0,0,10,0"
                                    Visibility="{Binding CanWrite, Converter={StaticResource BoolToVisConv}}" />
                            <Button Content="{x:Static loc:Strings.Action_Close}"
                                    Command="{Binding CloseDetailsCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="24,10" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Busy overlay -->
        <controls:BusyOverlay Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConv}}" />

    </Grid>
</UserControl>

