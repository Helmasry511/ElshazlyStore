<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.SalesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:helpers="clr-namespace:ElshazlyStore.Desktop.Helpers"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SalesViewModel}"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{x:Static loc:Strings.Nav_Sales}"
                       Style="{StaticResource PageTitleStyle}"
                       HorizontalAlignment="Center"
                       Margin="24,16,24,8" />

            <controls:NotificationBar Grid.Row="1"
                                      Message="{Binding NotificationMessage}"
                                      NotificationType="{Binding NotificationType}"
                                      Margin="24,0,24,4" />

            <DockPanel Grid.Row="2" Margin="24,0,24,8">
                <Button Content="{x:Static loc:Strings.Sales_CreateNew}"
                        Command="{Binding OpenCreateCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Visibility="{Binding CanWrite, Converter={StaticResource BoolToVisConv}}" />
                <Button Content="{x:Static loc:Strings.Action_Refresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_Search}"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_Clear}"
                        Command="{Binding ClearSearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"
                         DockPanel.Dock="Right"
                         Margin="8,0,0,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Border />
            </DockPanel>

            <DataGrid x:Name="SalesGrid"
                      Grid.Row="3"
                      ItemsSource="{Binding Items}"
                      Style="{StaticResource ThemedDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      RowStyle="{StaticResource ThemedDataGridRowStyle}"
                      CanUserSortColumns="False"
                      Sorting="OnSalesGridSorting"
                      Margin="24,0"
                      Visibility="{Binding HasError, Converter={StaticResource InverseBoolToVisConv}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Sales_InvoiceNumber}"
                                        Binding="{Binding InvoiceNumber}"
                                        SortMemberPath="number"
                                        CanUserSort="True"
                                        Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Date}"
                                        Binding="{Binding InvoiceDateUtc, StringFormat=yyyy-MM-dd}"
                                        SortMemberPath="date"
                                        CanUserSort="True"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Sales_Customer}"
                                        Binding="{Binding CustomerNameDisplay}"
                                        Width="*" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Warehouse}"
                                        Binding="{Binding WarehouseName}"
                                        Width="130" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Status}"
                                        Binding="{Binding StatusDisplay}"
                                        Width="90" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Sales_Total}"
                                        Binding="{Binding TotalAmount, Converter={StaticResource SmartNumberConv}}"
                                        SortMemberPath="total"
                                        CanUserSort="True"
                                        Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Sales_Cashier}"
                                        Binding="{Binding CashierUsername}"
                                        Width="120" />
                    <DataGridTemplateColumn Header="{x:Static loc:Strings.Field_Actions}" Width="420">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="{x:Static loc:Strings.Action_Details}"
                                            Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4" Margin="2,0" />
                                    <Button Command="{Binding DataContext.OpenEditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanWrite, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Setter Property="Content" Value="{x:Static loc:Strings.Action_Edit}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Posted">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="{x:Static loc:Strings.Action_Print}"
                                            Command="{Binding DataContext.PrintSaleDocCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4" Margin="2,0" />
                                    <Button Command="{Binding DataContext.PostSaleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanPost, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                                <Setter Property="Content" Value="{x:Static loc:Strings.Action_Post}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Posted">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Command="{Binding DataContext.DeleteSaleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanWrite, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                                                <Setter Property="Content" Value="{x:Static loc:Strings.Action_Delete}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Posted">
                                                        <Setter Property="IsEnabled" Value="False" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <controls:EmptyState Grid.Row="3"
                                 Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisConv}}" />
            <controls:ErrorDisplay Grid.Row="3"
                                   Message="{Binding ErrorMessage}"
                                   RetryCommand="{Binding RefreshCommand}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisConv}}" />

            <DockPanel Grid.Row="4" Margin="24,8">
                <TextBlock Text="{Binding PagingInfo}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="{x:Static loc:Strings.Paging_First}" Command="{Binding FirstPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Next}" Command="{Binding NextPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Last}" Command="{Binding LastPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                </StackPanel>
                <Border />
            </DockPanel>
        </Grid>

        <Grid Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVisConv}}">
            <Border Background="#80000000" />
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="760"
                    MaxHeight="580"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" TextElement.Foreground="{DynamicResource PrimaryTextBrush}">
                        <DockPanel Margin="0,0,0,16">
                            <Button Content="✕"
                                    Command="{Binding CloseDetailCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    DockPanel.Dock="Left"
                                    FontSize="14" />
                            <TextBlock Text="{x:Static loc:Strings.Sales_DetailTitle}"
                                       Style="{StaticResource PageTitleStyle}"
                                       HorizontalAlignment="Center"
                                       Margin="0" />
                        </DockPanel>

                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Sales_InvoiceNumber}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedSale.InvoiceNumber}" FlowDirection="LeftToRight"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="14" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Field_Status}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedSale.StatusDisplay}"
                                           FontFamily="{StaticResource PrimaryFont}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Sales_Customer}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedSale.CustomerNameDisplay}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="14" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Field_Warehouse}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedSale.WarehouseName}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="14" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Sales_Total}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedSale.TotalAmount, Converter={StaticResource SmartNumberConv}}" FlowDirection="LeftToRight"
                                           FontFamily="{StaticResource PrimaryFont}" FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Field_Date}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedSale.InvoiceDateUtc, StringFormat=yyyy-MM-dd HH:mm}" FlowDirection="LeftToRight"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="14" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Sales_Cashier}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedSale.CashierUsername}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="14" />
                            </StackPanel>
                        </UniformGrid>

                        <TextBlock Text="{x:Static loc:Strings.Field_Notes}" Style="{StaticResource FormLabelStyle}" />
                        <TextBlock Text="{Binding SelectedSale.Notes}" TextWrapping="Wrap"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="13" Margin="0,0,0,12" />

                        <TextBlock Text="{x:Static loc:Strings.Purchase_Lines}" Style="{StaticResource FormLabelStyle}" Margin="0,8,0,4" />
                        <DataGrid ItemsSource="{Binding SelectedSale.Lines}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Style="{StaticResource ThemedDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                                  CellStyle="{StaticResource ThemedDataGridCellStyle}"
                                  RowStyle="{StaticResource ThemedDataGridRowStyle}"
                                  MaxHeight="220">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Sku}" Binding="{Binding Sku}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_ProductName}" Binding="{Binding ProductName}" Width="*" />
                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Quantity}" Binding="{Binding Quantity, Converter={StaticResource SmartNumberConv}}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Sales_UnitPrice}" Binding="{Binding UnitPrice, Converter={StaticResource SmartNumberConv}}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Sales_Discount}" Binding="{Binding DiscountAmount, Converter={StaticResource SmartNumberConv}}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Purchase_LineTotal}" Binding="{Binding LineTotal, Converter={StaticResource SmartNumberConv}}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
                            <Button Content="{x:Static loc:Strings.Action_Print}"
                                    Command="{Binding PrintSaleDocCommand}"
                                    CommandParameter="{Binding SelectedSale}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,8" Margin="4,0" />
                            <Button Content="{x:Static loc:Strings.Action_Post}"
                                    Command="{Binding PostSaleCommand}"
                                    CommandParameter="{Binding SelectedSale}"
                                    Padding="16,8" Margin="4,0"
                                    Visibility="{Binding CanPost, Converter={StaticResource BoolToVisConv}}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
                                        <Setter Property="Padding" Value="16,8" />
                                        <Setter Property="Margin" Value="4,0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSale.Status}" Value="Posted">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{x:Static loc:Strings.Action_Close}"
                                    Command="{Binding CloseDetailCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,8" Margin="4,0" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConv}}">
            <Border Background="#80000000" />
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="900"
                    MaxHeight="680"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <StackPanel Margin="24,20" MaxWidth="850" TextElement.Foreground="{DynamicResource PrimaryTextBrush}">
                            <DockPanel Margin="0,0,0,16">
                                <Button Content="✕"
                                        Command="{Binding CancelEditCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,4"
                                        DockPanel.Dock="Left"
                                        FontSize="14" />
                                <TextBlock Text="{x:Static loc:Strings.Sales_FormTitle}"
                                           Style="{StaticResource PageTitleStyle}"
                                           HorizontalAlignment="Center"
                                           Margin="0" />
                            </DockPanel>

                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,8,12">
                                    <TextBlock Text="{x:Static loc:Strings.Sales_InvoiceNumber}" Style="{StaticResource FormLabelStyle}" />
                                    <Border Background="{DynamicResource SidebarBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,8">
                                        <TextBlock Text="{Binding FormInvoiceNumberDisplay}"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   FlowDirection="LeftToRight" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,12">
                                    <TextBlock Text="{x:Static loc:Strings.Field_Status}" Style="{StaticResource FormLabelStyle}" />
                                    <Border Background="{DynamicResource SidebarBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10,8">
                                        <TextBlock Text="{Binding FormStatus}"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </Border>
                                </StackPanel>
                                <StackPanel Margin="0,0,8,12">
                                    <TextBlock Text="{x:Static loc:Strings.Field_Date}" Style="{StaticResource FormLabelStyle}" />
                                    <DatePicker SelectedDate="{Binding FormInvoiceDate}"
                                                Style="{StaticResource ThemedDatePickerStyle}"
                                                MinWidth="180"
                                                FlowDirection="LeftToRight"
                                                IsEnabled="{Binding IsEditMode, Converter={StaticResource InvBool}}" />
                                    <TextBlock Text="{x:Static loc:Strings.Sales_InvoiceDateEditLocked}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisConv}}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,12">
                                    <TextBlock Text="{x:Static loc:Strings.Field_Warehouse}" Style="{StaticResource FormLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding Warehouses}"
                                              SelectedItem="{Binding SelectedWarehouse}"
                                              DisplayMemberPath="DisplayText"
                                              Style="{StaticResource ThemedComboBoxStyle}" />
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Text="{x:Static loc:Strings.Sales_Customer}" Style="{StaticResource FormLabelStyle}" />
                            <StackPanel Margin="0,0,0,12">
                                <Border Background="{DynamicResource SidebarBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        Margin="0,0,0,8"
                                        Visibility="{Binding IsCustomerSelected, Converter={StaticResource BoolToVisConv}}">
                                    <DockPanel>
                                        <Button Content="✕"
                                                Command="{Binding ClearCustomerSelectionCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="6,2"
                                                DockPanel.Dock="Left"
                                                FontSize="12" />
                                        <TextBlock Text="{Binding SelectedCustomerDisplay}"
                                                   FontFamily="{StaticResource PrimaryFont}"                                               FontSize="14"
                                               Foreground="{DynamicResource PrimaryTextBrush}"                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0" />
                                    </DockPanel>
                                </Border>

                                <TextBlock Text="{x:Static loc:Strings.Sales_AnonymousCustomer}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,0,0,8"
                                           Visibility="{Binding IsCustomerSelected, Converter={StaticResource InverseBoolToVisConv}}" />

                                <Grid Visibility="{Binding IsCustomerSelected, Converter={StaticResource InverseBoolToVisConv}}">
                                    <TextBox Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ThemedTextBoxStyle}" />
                                    <Popup IsOpen="{Binding HasCustomerSearchResults}"
                                           PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                                           Placement="Bottom"
                                           MaxHeight="220"
                                           StaysOpen="False">
                                        <Border Background="{DynamicResource ContentBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                MinWidth="320">
                                            <ListBox ItemsSource="{Binding CustomerSearchResults}"
                                                     BorderThickness="0"
                                                     Background="Transparent">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8,6" Cursor="Hand">
                                                            <Border.InputBindings>
                                                                <MouseBinding MouseAction="LeftClick"
                                                                              Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                              CommandParameter="{Binding}" />
                                                            </Border.InputBindings>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontFamily="{StaticResource PrimaryFont}"
                                                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Code}" FlowDirection="LeftToRight"
                                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                                               FontFamily="{StaticResource PrimaryFont}" />
                                                                    <TextBlock Text=" — " Foreground="{DynamicResource SecondaryTextBrush}" />
                                                                    <TextBlock Text="{Binding Phone}" FlowDirection="LeftToRight"
                                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                                               FontFamily="{StaticResource PrimaryFont}" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="{x:Static loc:Strings.Sales_QuickAddCustomer}"
                                            Command="{Binding OpenCustomerQuickAddCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="10,6"
                                            Margin="0,0,8,0"
                                            Visibility="{Binding CanCreateCustomers, Converter={StaticResource BoolToVisConv}}" />
                                    <Button Content="{x:Static loc:Strings.Sales_AnonymousAction}"
                                            Command="{Binding ClearCustomerSelectionCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="10,6" />
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="{Binding FormInfo}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding FormInfo, Converter={StaticResource StringNotEmptyToVis}}" />

                            <TextBlock Text="{x:Static loc:Strings.POS_NotesOptional}" Style="{StaticResource SecondaryFieldLabelStyle}" />
                            <TextBox Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CompactTextBoxStyle}"
                                     Margin="0,0,0,12"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="44" />

                            <DockPanel Margin="0,8,0,4">
                                <TextBlock Text="{x:Static loc:Strings.Purchase_Lines}" Style="{StaticResource FormLabelStyle}" DockPanel.Dock="Right" />
                                <Button Content="{x:Static loc:Strings.Action_AddLine}"
                                        Command="{Binding AddLineCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,4"
                                        DockPanel.Dock="Left" />
                                <Border />
                            </DockPanel>

                            <Grid Margin="0,4,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Static loc:Strings.Field_ProductName}"
                                           FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock Grid.Column="1" Text="{x:Static loc:Strings.Field_Quantity}"
                                           FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                                <TextBlock Grid.Column="2" Text="{x:Static loc:Strings.Sales_UnitPrice}"
                                           FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                                <TextBlock Grid.Column="3" Text="{x:Static loc:Strings.Sales_Discount}"
                                           FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                                <TextBlock Grid.Column="4" Text="{x:Static loc:Strings.Purchase_LineTotal}"
                                           FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            </Grid>
                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4" />

                            <ItemsControl ItemsSource="{Binding Lines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,6"
                                                Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="80" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="100" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                    <TextBlock Text="{Binding VariantDisplay}"
                                                               FontFamily="{StaticResource PrimaryFont}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Visibility="{Binding VariantDisplay, Converter={StaticResource StringNotEmptyToVis}}" />
                                                    <WrapPanel Margin="0,4,0,0">
                                                        <Button Content="{x:Static loc:Strings.Stock_SelectVariant}"
                                                                Command="{Binding DataContext.StartLineVariantSearchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                Padding="6,2" FontSize="11" />
                                                        <Button Content="{Binding RetailPriceLabel}"
                                                                Command="{Binding DataContext.ApplyRetailPriceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                Padding="6,2" FontSize="11"
                                                                Margin="4,0,0,0"
                                                                Visibility="{Binding RetailPriceLabel, Converter={StaticResource StringNotEmptyToVis}}" />
                                                        <Button Content="{Binding WholesalePriceLabel}"
                                                                Command="{Binding DataContext.ApplyWholesalePriceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                Padding="6,2" FontSize="11"
                                                                Margin="4,0,0,0"
                                                                Visibility="{Binding WholesalePriceLabel, Converter={StaticResource StringNotEmptyToVis}}" />
                                                    </WrapPanel>
                                                </StackPanel>

                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Quantity, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource CompactTextBoxStyle}"
                                                         FlowDirection="LeftToRight"
                                                         Margin="4,0"
                                                         MinWidth="60"
                                                         helpers:NumericTextBoxBehavior.IsEnabled="True"
                                                         helpers:NumericTextBoxBehavior.FractionDigits="3"
                                                         helpers:NumericTextBoxBehavior.AutoScaleIntegerInput="False" />

                                                <TextBox Grid.Column="2"
                                                         Text="{Binding UnitPrice, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource CompactTextBoxStyle}"
                                                         FlowDirection="LeftToRight"
                                                         Margin="4,0"
                                                         MinWidth="80"
                                                         helpers:NumericTextBoxBehavior.IsEnabled="True"
                                                         helpers:NumericTextBoxBehavior.FractionDigits="2"
                                                         helpers:NumericTextBoxBehavior.AutoScaleIntegerInput="True" />

                                                <TextBox Grid.Column="3"
                                                         Text="{Binding DiscountAmount, UpdateSourceTrigger=LostFocus}"
                                                         Style="{StaticResource CompactTextBoxStyle}"
                                                         FlowDirection="LeftToRight"
                                                         Margin="4,0"
                                                         MinWidth="80"
                                                         helpers:NumericTextBoxBehavior.IsEnabled="True"
                                                         helpers:NumericTextBoxBehavior.FractionDigits="2"
                                                         helpers:NumericTextBoxBehavior.AutoScaleIntegerInput="True" />

                                                <TextBlock Grid.Column="4"
                                                           Text="{Binding LineTotal, Converter={StaticResource SmartNumberConv}}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="14"
                                                           FontWeight="Bold"
                                                           FlowDirection="LeftToRight"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0" />

                                                <Button Grid.Column="5"
                                                        Content="{x:Static loc:Strings.Action_RemoveLine}"
                                                        Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DangerButtonStyle}"
                                                        Padding="6,2" Margin="4,0,0,0"
                                                        VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Margin="0,4,0,0"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="8"
                                    Visibility="{Binding IsVariantSearchOpen, Converter={StaticResource BoolToVisConv}}">
                                <StackPanel>
                                    <TextBox Text="{Binding VariantSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ThemedTextBoxStyle}"
                                             FlowDirection="LeftToRight" />
                                    <TextBlock Text="{x:Static loc:Strings.State_Loading}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding IsVariantSearchLoading, Converter={StaticResource BoolToVisConv}}" />
                                    <TextBlock Text="{Binding VariantSearchNote}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding VariantSearchNote, Converter={StaticResource StringNotEmptyToVis}}" />
                                    <ListBox ItemsSource="{Binding VariantSearchResults}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             MaxHeight="220"
                                             Visibility="{Binding HasVariantSearchResults, Converter={StaticResource BoolToVisConv}}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.SelectVariantForLineCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                      CommandParameter="{Binding}" />
                                                    </Border.InputBindings>
                                                    <DockPanel>
                                                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                                                            <TextBlock Text="{Binding ProductName}"
                                                                       FontFamily="{StaticResource PrimaryFont}"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                                            <TextBlock Text="{Binding Color, StringFormat=' ({0})'}"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       Visibility="{Binding Color, Converter={StaticResource StringNotEmptyToVis}}" />
                                                            <TextBlock Text="{Binding Size, StringFormat=' [{0}]'}"
                                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                                       Visibility="{Binding Size, Converter={StaticResource StringNotEmptyToVis}}" />
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <TextBlock Text="{Binding Sku}" FlowDirection="LeftToRight"
                                                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                            <TextBlock Text="{Binding Barcode}" FlowDirection="LeftToRight"
                                                                       FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       Margin="12,0,0,0"
                                                                       Visibility="{Binding Barcode, Converter={StaticResource StringNotEmptyToVis}}" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource SidebarBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,10"
                                    Margin="0,12,0,8">
                                <DockPanel>
                                    <TextBlock Text="{x:Static loc:Strings.Sales_Total}"
                                               Style="{StaticResource FormLabelStyle}"
                                               DockPanel.Dock="Right"
                                               VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding InvoiceTotal, Converter={StaticResource SmartNumberConv}}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               FlowDirection="LeftToRight"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               DockPanel.Dock="Left"
                                               VerticalAlignment="Center" />
                                    <Border />
                                </DockPanel>
                            </Border>

                            <TextBlock Text="{Binding FormError}"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"
                                       Visibility="{Binding FormError, Converter={StaticResource StringNotEmptyToVis}}" />

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="{x:Static loc:Strings.Action_Save}"
                                        Command="{Binding SaveCommand}"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Padding="24,8" Margin="0,0,8,0"
                                        IsEnabled="{Binding IsSaving, Converter={StaticResource InvBool}}" />
                                <Button Content="{x:Static loc:Strings.Action_Cancel}"
                                        Command="{Binding CancelEditCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="24,8" />
                            </StackPanel>
                        </StackPanel>

                        <Grid Visibility="{Binding IsCustomerQuickAddOpen, Converter={StaticResource BoolToVisConv}}">
                            <Border Background="#70000000" />
                            <Border Background="{DynamicResource ContentBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    MaxWidth="520"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Padding="0"
                                    Margin="24">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="420">
                                    <StackPanel Margin="24,20" MaxWidth="470">
                                        <DockPanel Margin="0,0,0,16">
                                            <Button Content="✕"
                                                    Command="{Binding CloseCustomerQuickAddCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="8,4"
                                                    DockPanel.Dock="Left"
                                                    FontSize="14" />
                                            <TextBlock Text="{x:Static loc:Strings.Sales_QuickAddCustomer}"
                                                       Style="{StaticResource PageTitleStyle}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0" />
                                        </DockPanel>

                                        <TextBlock Text="{x:Static loc:Strings.Field_Name}" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Text="{Binding NewCustomerName, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ThemedTextBoxStyle}"
                                                 Margin="0,0,0,12" />

                                        <TextBlock Text="{x:Static loc:Strings.Field_Phone}" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Text="{Binding NewCustomerPhone, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ThemedTextBoxStyle}"
                                                 Margin="0,0,0,12"
                                                 FlowDirection="LeftToRight" />

                                        <Border BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="12,10"
                                                Margin="0,0,0,12"
                                                Visibility="{Binding HasCustomerQuickAddSuggestions, Converter={StaticResource BoolToVisConv}}">
                                            <StackPanel>
                                                <TextBlock Text="{x:Static loc:Strings.Sales_ExistingCustomerHint}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="{StaticResource FontSizeSmall}"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,0,0,8"
                                                           TextWrapping="Wrap" />
                                                <ItemsControl ItemsSource="{Binding CustomerQuickAddSuggestions}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="{DynamicResource BorderBrush}"
                                                                    BorderThickness="0,0,0,1"
                                                                    Padding="0,6">
                                                                <DockPanel>
                                                                    <Button Content="{x:Static loc:Strings.Sales_UseExistingCustomer}"
                                                                            Command="{Binding DataContext.UseQuickAddSuggestionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{StaticResource SecondaryButtonStyle}"
                                                                            Padding="8,4"
                                                                            DockPanel.Dock="Left" />
                                                                    <StackPanel Margin="8,0,0,0">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding Code}" FlowDirection="LeftToRight"
                                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                                       FontFamily="{StaticResource PrimaryFont}" />
                                                                            <TextBlock Text=" — " Foreground="{DynamicResource SecondaryTextBrush}" />
                                                                            <TextBlock Text="{Binding Phone}" FlowDirection="LeftToRight"
                                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                                       FontFamily="{StaticResource PrimaryFont}" />
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                    <Border />
                                                                </DockPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock Text="{Binding NewCustomerError}"
                                                   Foreground="{DynamicResource ErrorBrush}"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   FontSize="{StaticResource FontSizeSmall}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,12"
                                                   Visibility="{Binding NewCustomerError, Converter={StaticResource StringNotEmptyToVis}}" />

                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="{x:Static loc:Strings.Action_Save}"
                                                    Command="{Binding SaveNewCustomerCommand}"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    Padding="24,8" Margin="0,0,8,0"
                                                    IsEnabled="{Binding IsSavingCustomer, Converter={StaticResource InvBool}}" />
                                            <Button Content="{x:Static loc:Strings.Action_Cancel}"
                                                    Command="{Binding CloseCustomerQuickAddCommand}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Padding="24,8" />
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <controls:BusyOverlay Visibility="{Binding IsLoadingOverlayVisible, Converter={StaticResource BoolToVisConv}}" />
    </Grid>
</UserControl>