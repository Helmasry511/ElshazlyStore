<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.CustomerPaymentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:CustomerPaymentsViewModel}"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">
    <!-- CP-2-R2: toolbar customer typeahead, simplified context bar, readonly modal customer -->

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <!-- ═══ Main list view ═══ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ══ Page header ══ -->
            <Border Grid.Row="0" Padding="28,18,28,10">
                <DockPanel>
                    <!-- Back button -->
                    <Button DockPanel.Dock="Left"
                            Content="{x:Static loc:Strings.CustomerPayments_BackToCustomers}"
                            Command="{Binding NavigateBackToCustomersCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Padding="10,7"
                            VerticalAlignment="Center"
                            Margin="0,0,14,0" />

                    <TextBlock DockPanel.Dock="Left"
                               Text="{x:Static loc:Strings.Nav_CustomerPayments}"
                               FontFamily="{StaticResource PrimaryFont}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center" />
                </DockPanel>
            </Border>

            <!-- ══ Customer Context Bar (Row 3) ══
                 Two states:
                   1. HasPresetCustomer=true  — show customer name (bold) + outstanding + [إلغاء التصفية]
                   2. HasPresetCustomer=false — show "جميع العملاء" label (global mode)
                 Customer switching is done via the toolbar typeahead — no "Change Customer" button needed. -->
            <Border Grid.Row="3"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,1"
                    Padding="24,10,24,10">
                <Grid>

                    <!-- ─── State 1: Customer selected ─── -->
                    <DockPanel Visibility="{Binding HasPresetCustomer, Converter={StaticResource BoolToVisConv}}">
                        <!-- [إلغاء التصفية] on right (RTL: Dock=Left → renders on the right) -->
                        <Button DockPanel.Dock="Left"
                                Content="{x:Static loc:Strings.CustomerPayments_ClearFilter}"
                                Command="{Binding ClearCustomerFilterCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Padding="10,6"
                                VerticalAlignment="Center" />

                        <!-- Customer identity: name + outstanding -->
                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                            <TextBlock Text="{Binding PresetCustomerName}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />

                            <!-- Outstanding (only when ACCOUNTING_READ granted and value loaded) -->
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,3,0,0"
                                        Visibility="{Binding HasOutstandingDisplay, Converter={StaticResource BoolToVisConv}}">
                                <TextBlock Text="{x:Static loc:Strings.CustomerPayments_OutstandingLabel}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock Text=": "
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding OutstandingAmountDisplay}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AccentBrush}" />
                            </StackPanel>

                            <!-- Outstanding loading indicator -->
                            <TextBlock Text="{x:Static loc:Strings.CustomerPayments_OutstandingLoading}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Margin="0,3,0,0"
                                       Visibility="{Binding IsLoadingOutstanding, Converter={StaticResource BoolToVisConv}}" />
                        </StackPanel>
                    </DockPanel>

                    <!-- ─── State 2: No customer filter (global / all-customers mode) ─── -->
                    <DockPanel Visibility="{Binding HasPresetCustomer, Converter={StaticResource InverseBoolToVisConv}}">
                        <TextBlock Text="{x:Static loc:Strings.CustomerPayments_AllCustomers}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                </Grid>
            </Border>

            <!-- ══ NotificationBar ══ -->
            <controls:NotificationBar Grid.Row="1"
                                      Message="{Binding NotificationMessage}"
                                      NotificationType="{Binding NotificationType}"
                                      Margin="24,0,24,4" />

            <!-- ══ Toolbar ══ -->
            <DockPanel Grid.Row="2" Margin="24,0,24,10">
                <Button Content="{x:Static loc:Strings.Payment_CreateNew}"
                        Command="{Binding OpenCreateCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="14,9"
                        DockPanel.Dock="Left"
                        Visibility="{Binding CanWrite, Converter={StaticResource BoolToVisConv}}" />
                <Button Content="{x:Static loc:Strings.Action_Refresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,9"
                        DockPanel.Dock="Left"
                        Margin="6,0,0,0" />
                <!-- Customer typeahead: the primary customer search/select entry point -->
                <Grid DockPanel.Dock="Right" VerticalAlignment="Center" MinWidth="240" MaxWidth="380">
                    <TextBox Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource SearchTextBoxStyle}" />
                    <Popup IsOpen="{Binding HasCustomerSearchResults}"
                           PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                           Placement="Bottom"
                           MaxHeight="220"
                           StaysOpen="False">
                        <Border Background="{DynamicResource ContentBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                MinWidth="240">
                            <ListBox ItemsSource="{Binding CustomerSearchResults}"
                                     BorderThickness="0"
                                     Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                              CommandParameter="{Binding}" />
                                            </Border.InputBindings>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text=" — "
                                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                                <TextBlock Text="{Binding Code}"
                                                           FlowDirection="LeftToRight"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           FontFamily="{StaticResource PrimaryFont}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>
                <Border />
            </DockPanel>

            <!-- ══ DataGrid card ══ -->
            <Border Grid.Row="4"
                    Margin="24,0"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    ClipToBounds="True"
                    Background="{DynamicResource CardBackgroundBrush}"
                    Visibility="{Binding HasError, Converter={StaticResource InverseBoolToVisConv}}">
                <DataGrid ItemsSource="{Binding Items}"
                          Style="{StaticResource ThemedDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                          CellStyle="{StaticResource ThemedDataGridCellStyle}"
                          RowStyle="{StaticResource ThemedDataGridRowStyle}"
                          BorderThickness="0"
                          Margin="0">
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="{x:Static loc:Strings.Payment_Number}"
                                            Binding="{Binding PaymentNumber}"
                                            Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FlowDirection" Value="LeftToRight" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{x:Static loc:Strings.CustomerPayments_Party}"
                                            Binding="{Binding PartyName}"
                                            Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{x:Static loc:Strings.Payment_Amount}"
                                            Binding="{Binding Amount, StringFormat=N2}"
                                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FlowDirection" Value="LeftToRight" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{x:Static loc:Strings.Payment_Method}"
                                            Binding="{Binding MethodDisplay}"
                                            Width="100" />

                        <DataGridTextColumn Header="{x:Static loc:Strings.Payment_Reference}"
                                            Binding="{Binding Reference}"
                                            Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FlowDirection" Value="LeftToRight" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="{x:Static loc:Strings.Field_Date}"
                                            Binding="{Binding DateDisplay}"
                                            Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FlowDirection" Value="LeftToRight" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="{x:Static loc:Strings.Field_Actions}" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{x:Static loc:Strings.Payment_PrintReceipt}"
                                            Command="{Binding DataContext.PrintPaymentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4" Margin="2,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Empty / Error states -->
            <controls:EmptyState Grid.Row="4"
                                 Margin="24,0"
                                 Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisConv}}" />
            <controls:ErrorDisplay Grid.Row="4"
                                   Margin="24,0"
                                   Message="{Binding ErrorMessage}"
                                   RetryCommand="{Binding RefreshCommand}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisConv}}" />

            <!-- ══ Paging ══ -->
            <DockPanel Grid.Row="5" Margin="24,8,24,12">
                <TextBlock Text="{Binding PagingInfo}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="{x:Static loc:Strings.Paging_First}"    Command="{Binding FirstPageCommand}"    Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Next}"     Command="{Binding NextPageCommand}"     Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Last}"     Command="{Binding LastPageCommand}"     Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                </StackPanel>
                <Border />
            </DockPanel>

        </Grid>

        <!-- ═══ MODAL: Create Payment ═══ -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConv}}">
            <!-- Dim backdrop -->
            <Border Background="#88000000" />
            <!-- Modal card -->
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    MaxWidth="520"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="28" Opacity="0.22" ShadowDepth="6" Direction="270" />
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="560">
                    <StackPanel Margin="28,24,28,24" MaxWidth="460">

                        <!-- Header -->
                        <DockPanel Margin="0,0,0,18">
                            <Button Content="✕"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    FontSize="14"
                                    DockPanel.Dock="Left" />
                            <TextBlock Text="{x:Static loc:Strings.CustomerPayments_CreateFormTitle}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <!-- Customer field:
                             - When page already has a selected customer (IsModalCustomerReadonly=true):
                               show a readonly bold label — no typeahead, no duplicate dropdown.
                             - When page is in global mode (IsModalCustomerReadonly=false):
                               show modal-specific typeahead with its own separate results collection. -->
                        <TextBlock Text="{x:Static loc:Strings.CustomerPayments_Party}"
                                   Style="{StaticResource FormLabelStyle}" />

                        <!-- Readonly customer display (preset context) -->
                        <Border Visibility="{Binding IsModalCustomerReadonly, Converter={StaticResource BoolToVisConv}}"
                                Margin="0,0,0,14"
                                Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12,9">
                            <TextBlock Text="{Binding PresetCustomerName}"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                        </Border>

                        <!-- Editable modal customer typeahead (global mode) -->
                        <Grid Visibility="{Binding IsModalCustomerReadonly, Converter={StaticResource InverseBoolToVisConv}}"
                              Margin="0,0,0,14">
                            <TextBox Text="{Binding ModalCustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ThemedTextBoxStyle}" />
                            <Popup IsOpen="{Binding HasModalCustomerSearchResults}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                                   Placement="Bottom"
                                   MaxHeight="220"
                                   StaysOpen="False">
                                <Border Background="{DynamicResource ContentBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        MinWidth="300">
                                    <ListBox ItemsSource="{Binding ModalCustomerSearchResults}"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.SelectModalCustomerCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                      CommandParameter="{Binding}" />
                                                    </Border.InputBindings>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text=" — "
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="{Binding Code}"
                                                                   FlowDirection="LeftToRight"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                   FontFamily="{StaticResource PrimaryFont}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Amount -->
                        <TextBlock Text="{x:Static loc:Strings.Payment_Amount}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormAmount, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 FlowDirection="LeftToRight" />

                        <!-- Method -->
                        <TextBlock Text="{x:Static loc:Strings.Payment_Method}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <ComboBox ItemsSource="{Binding PaymentMethods}"
                                  SelectedItem="{Binding FormMethod}"
                                  Style="{StaticResource ThemedComboBoxStyle}"
                                  Margin="0,0,0,14" />

                        <!-- Wallet name (optional — for EWallet/InstaPay) -->
                        <TextBlock Text="{x:Static loc:Strings.Payment_WalletName}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormWalletName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14" />

                        <!-- Reference -->
                        <TextBlock Text="{x:Static loc:Strings.Payment_Reference}"
                                   Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormReference, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}"
                                 Margin="0,0,0,14"
                                 FlowDirection="LeftToRight" />

                        <!-- Form error block -->
                        <Border Visibility="{Binding FormError, Converter={StaticResource StringNotEmptyToVis}}"
                                Background="{DynamicResource ErrorBrush}"
                                Opacity="0.95"
                                CornerRadius="6"
                                Margin="0,0,0,14">
                            <Border.OpacityMask>
                                <SolidColorBrush Color="White" Opacity="0.13" />
                            </Border.OpacityMask>
                            <TextBlock Text="{Binding FormError}"
                                       Foreground="White"
                                       FontFamily="{StaticResource PrimaryFont}"
                                       FontSize="{StaticResource FontSizeSmall}"
                                       TextWrapping="Wrap"
                                       Margin="12,8" />
                        </Border>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Command="{Binding SaveCommand}"
                                    Padding="28,10"
                                    Margin="0,0,10,0"
                                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvBool}}">
                                <Button.Content>
                                    <TextBlock FontFamily="{StaticResource PrimaryFont}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{x:Static loc:Strings.Action_Save}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                                        <Setter Property="Text" Value="جاري الحفظ…" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Button.Content>
                            </Button>
                            <Button Content="{x:Static loc:Strings.Action_Cancel}"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="24,10" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Busy overlay -->
        <controls:BusyOverlay Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConv}}" />

    </Grid>
</UserControl>
