<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.PurchasesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:PurchasesViewModel}"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <!-- ═══ Main list view ═══ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{x:Static loc:Strings.Nav_Purchases}"
                       Style="{StaticResource PageTitleStyle}"
                       HorizontalAlignment="Center"
                       Margin="24,16,24,8" />

            <!-- Notification Bar -->
            <controls:NotificationBar Grid.Row="1"
                                      Message="{Binding NotificationMessage}"
                                      NotificationType="{Binding NotificationType}"
                                      Margin="24,0,24,4" />

            <!-- Toolbar -->
            <DockPanel Grid.Row="2" Margin="24,0,24,8">
                <Button Content="{x:Static loc:Strings.Purchase_CreateNew}"
                        Command="{Binding OpenCreateCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Visibility="{Binding CanWrite, Converter={StaticResource BoolToVisConv}}" />
                <Button Content="{x:Static loc:Strings.Action_Refresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_Search}"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_Clear}"
                        Command="{Binding ClearSearchCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"
                         DockPanel.Dock="Right"
                         Margin="8,0,0,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Border />
            </DockPanel>

            <!-- DataGrid -->
            <DataGrid Grid.Row="3"
                      ItemsSource="{Binding Items}"
                      Style="{StaticResource ThemedDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      RowStyle="{StaticResource ThemedDataGridRowStyle}"
                      Margin="24,0"
                      Visibility="{Binding HasError, Converter={StaticResource InverseBoolToVisConv}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Purchase_DocNumber}" Binding="{Binding DocumentNumber}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Purchase_Supplier}" Binding="{Binding SupplierName}" Width="*" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Purchase_Warehouse}" Binding="{Binding WarehouseName}" Width="120" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Purchase_Total}" Binding="{Binding Total, StringFormat=N2}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Status}" Binding="{Binding StatusDisplay}" Width="90" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Date}" Binding="{Binding CreatedAtUtc, StringFormat=yyyy-MM-dd}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="{x:Static loc:Strings.Field_Actions}" Width="320">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="{x:Static loc:Strings.Action_Details}"
                                            Command="{Binding DataContext.OpenDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4" Margin="2,0" />
                                    <Button Content="{x:Static loc:Strings.Action_Edit}"
                                            Command="{Binding DataContext.OpenEditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanWrite, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}" />
                                    <Button Content="{x:Static loc:Strings.Action_Print}"
                                            Command="{Binding DataContext.PrintPurchaseDocCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Padding="8,4" Margin="2,0" />
                                    <Button Content="{x:Static loc:Strings.Action_Post}"
                                            Command="{Binding DataContext.PostPurchaseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanPost, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}" />
                                    <Button Content="{x:Static loc:Strings.Action_Delete}"
                                            Command="{Binding DataContext.DeletePurchaseCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Padding="8,4" Margin="2,0"
                                            Visibility="{Binding DataContext.CanWrite, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisConv}}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty / Error states -->
            <controls:EmptyState Grid.Row="3"
                                 Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisConv}}" />
            <controls:ErrorDisplay Grid.Row="3"
                                   Message="{Binding ErrorMessage}"
                                   RetryCommand="{Binding RefreshCommand}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisConv}}" />

            <!-- Paging -->
            <DockPanel Grid.Row="4" Margin="24,8">
                <TextBlock Text="{Binding PagingInfo}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="{x:Static loc:Strings.Paging_First}" Command="{Binding FirstPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Next}" Command="{Binding NextPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Last}" Command="{Binding LastPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                </StackPanel>
                <Border />
            </DockPanel>
        </Grid>

        <!-- ═══ MODAL: Detail view ═══ -->
        <Grid Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVisConv}}">
            <Border Background="#80000000" />
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="700"
                    MaxHeight="550"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" DataContext="{Binding}">
                        <!-- Header -->
                        <DockPanel Margin="0,0,0,16">
                            <Button Content="✕"
                                    Command="{Binding CloseDetailCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    DockPanel.Dock="Left"
                                    FontSize="14" />
                            <TextBlock Text="{x:Static loc:Strings.Purchase_DetailTitle}"
                                       Style="{StaticResource PageTitleStyle}"
                                       HorizontalAlignment="Center"
                                       Margin="0" />
                        </DockPanel>

                        <!-- Purchase fields -->
                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Purchase_DocNumber}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedPurchase.DocumentNumber}" FlowDirection="LeftToRight"
                                           FontFamily="{StaticResource PrimaryFont}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Field_Status}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedPurchase.StatusDisplay}"
                                           FontFamily="{StaticResource PrimaryFont}" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Purchase_Supplier}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedPurchase.SupplierName}"
                                           FontFamily="{StaticResource PrimaryFont}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Purchase_Warehouse}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedPurchase.WarehouseName}"
                                           FontFamily="{StaticResource PrimaryFont}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Purchase_Total}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedPurchase.Total, StringFormat=N2}" FlowDirection="LeftToRight"
                                           FontFamily="{StaticResource PrimaryFont}" FontWeight="Bold" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,8">
                                <TextBlock Text="{x:Static loc:Strings.Field_Date}" Style="{StaticResource FormLabelStyle}" />
                                <TextBlock Text="{Binding SelectedPurchase.CreatedAtUtc, StringFormat=yyyy-MM-dd HH:mm}" FlowDirection="LeftToRight"
                                           FontFamily="{StaticResource PrimaryFont}" />
                            </StackPanel>
                        </UniformGrid>

                        <!-- Notes -->
                        <TextBlock Text="{x:Static loc:Strings.Field_Notes}" Style="{StaticResource FormLabelStyle}" />
                        <TextBlock Text="{Binding SelectedPurchase.Notes}" TextWrapping="Wrap"
                                   FontFamily="{StaticResource PrimaryFont}" Margin="0,0,0,12" />

                        <!-- Lines table -->
                        <TextBlock Text="{x:Static loc:Strings.Purchase_Lines}" Style="{StaticResource FormLabelStyle}" Margin="0,8,0,4" />
                        <DataGrid ItemsSource="{Binding SelectedPurchase.Lines}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  HeadersVisibility="Column"
                                  Style="{StaticResource ThemedDataGridStyle}"
                                  ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                                  CellStyle="{StaticResource ThemedDataGridCellStyle}"
                                  RowStyle="{StaticResource ThemedDataGridRowStyle}"
                                  MaxHeight="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Sku}" Binding="{Binding VariantSku}" Width="120">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_ProductName}" Binding="{Binding ProductName}" Width="*" />
                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_Quantity}" Binding="{Binding Quantity}" Width="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Field_UnitCost}" Binding="{Binding UnitCost, StringFormat=N2}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="{x:Static loc:Strings.Purchase_LineTotal}" Binding="{Binding LineTotal, StringFormat=N2}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FlowDirection" Value="LeftToRight" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Action buttons in detail -->
                        <StackPanel Orientation="Horizontal" Margin="0,16,0,0" HorizontalAlignment="Center">
                            <Button Content="{x:Static loc:Strings.Action_Print}"
                                    Command="{Binding PrintPurchaseDocCommand}"
                                    CommandParameter="{Binding SelectedPurchase}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,8" Margin="4,0" />
                            <Button Content="{x:Static loc:Strings.Action_Post}"
                                    Command="{Binding PostPurchaseCommand}"
                                    CommandParameter="{Binding SelectedPurchase}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="16,8" Margin="4,0"
                                    Visibility="{Binding CanPost, Converter={StaticResource BoolToVisConv}}" />
                            <Button Content="{x:Static loc:Strings.Action_Close}"
                                    Command="{Binding CloseDetailCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="16,8" Margin="4,0" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══ MODAL: Create/Edit form ═══ -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConv}}">
            <Border Background="#80000000" />
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="750"
                    MaxHeight="600"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" MaxWidth="700">
                        <!-- Header -->
                        <DockPanel Margin="0,0,0,16">
                            <Button Content="✕"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    DockPanel.Dock="Left"
                                    FontSize="14" />
                            <TextBlock Text="{x:Static loc:Strings.Purchase_FormTitle}"
                                       Style="{StaticResource PageTitleStyle}"
                                       HorizontalAlignment="Center"
                                       Margin="0" />
                        </DockPanel>

                        <!-- Supplier typeahead -->
                        <TextBlock Text="{x:Static loc:Strings.Purchase_Supplier}" Style="{StaticResource FormLabelStyle}" />
                        <Grid Margin="0,0,0,12">
                            <TextBox Text="{Binding SupplierSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ThemedTextBoxStyle}" />
                            <Popup IsOpen="{Binding HasSupplierSearchResults}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                                   Placement="Bottom"
                                   MaxHeight="220"
                                   StaysOpen="False">
                                <Border Background="{DynamicResource ContentBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        MinWidth="300">
                                    <ListBox ItemsSource="{Binding SupplierSearchResults}"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.SelectSupplierCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                      CommandParameter="{Binding}" />
                                                    </Border.InputBindings>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource PrimaryFont}" />
                                                        <TextBlock Text=" — " Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="{Binding Code}" FlowDirection="LeftToRight"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" FontFamily="{StaticResource PrimaryFont}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Warehouse -->
                        <TextBlock Text="{x:Static loc:Strings.Purchase_Warehouse}" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox ItemsSource="{Binding Warehouses}"
                                  SelectedItem="{Binding SelectedWarehouse}"
                                  DisplayMemberPath="DisplayText"
                                  Style="{StaticResource ThemedComboBoxStyle}"
                                  Margin="0,0,0,12" />

                        <!-- Doc number -->
                        <TextBlock Text="{x:Static loc:Strings.Purchase_DocNumber}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormDocumentNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,12"
                                 FlowDirection="LeftToRight" />

                        <!-- Notes -->
                        <TextBlock Text="{x:Static loc:Strings.Field_Notes}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormNotes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,12"
                                 TextWrapping="Wrap" AcceptsReturn="True" MinHeight="40" />

                        <!-- Lines header -->
                        <DockPanel Margin="0,8,0,4">
                            <TextBlock Text="{x:Static loc:Strings.Purchase_Lines}" Style="{StaticResource FormLabelStyle}" DockPanel.Dock="Right" />
                            <Button Content="{x:Static loc:Strings.Action_AddLine}"
                                    Command="{Binding AddLineCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    DockPanel.Dock="Left" />
                            <Border />
                        </DockPanel>

                        <!-- Lines header row -->
                        <Grid Margin="0,4,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Static loc:Strings.Field_ProductName}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                            <TextBlock Grid.Column="1" Text="{x:Static loc:Strings.Field_Quantity}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="2" Text="{x:Static loc:Strings.Field_UnitCost}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                            <TextBlock Grid.Column="3" Text="{x:Static loc:Strings.Purchase_LineTotal}"
                                       FontFamily="{StaticResource PrimaryFont}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="4,0" />
                        </Grid>
                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4" />

                        <!-- Lines list -->
                        <ItemsControl ItemsSource="{Binding Lines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,6"
                                            Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Variant picker -->
                                            <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                <TextBlock Text="{Binding VariantDisplay}"
                                                           FontFamily="{StaticResource PrimaryFont}"
                                                           FontSize="{StaticResource FontSizeSmall}"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding VariantDisplay, Converter={StaticResource StringNotEmptyToVis}}" />
                                                <Button Content="{x:Static loc:Strings.Stock_SelectVariant}"
                                                        Command="{Binding DataContext.StartLineVariantSearchCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Padding="6,2" FontSize="11" HorizontalAlignment="Right" />
                                            </StackPanel>

                                            <!-- Quantity -->
                                            <StackPanel Grid.Column="1" Margin="4,0">
                                                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource ThemedTextBoxStyle}"
                                                         FlowDirection="LeftToRight"
                                                         MinWidth="70" />
                                            </StackPanel>

                                            <!-- Unit Cost -->
                                            <StackPanel Grid.Column="2" Margin="4,0">
                                                <TextBox Text="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{StaticResource ThemedTextBoxStyle}"
                                                         FlowDirection="LeftToRight"
                                                         MinWidth="70" />
                                            </StackPanel>

                                            <!-- Line Total -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding LineTotal, StringFormat=N2}"
                                                       FontFamily="{StaticResource PrimaryFont}"
                                                       FontSize="{StaticResource FontSizeSmall}"
                                                       FlowDirection="LeftToRight"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0" />

                                            <!-- Remove -->
                                            <Button Grid.Column="4"
                                                    Content="{x:Static loc:Strings.Action_RemoveLine}"
                                                    Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Padding="6,2" Margin="4,0,0,0"
                                                    VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Variant search panel (shared) -->
                        <Border Margin="0,4,0,0"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="8"
                                Visibility="{Binding IsVariantSearchOpen, Converter={StaticResource BoolToVisConv}}">
                            <StackPanel>
                                <TextBox x:Name="VariantSearchBox"
                                         Text="{Binding VariantSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource ThemedTextBoxStyle}"
                                         FlowDirection="LeftToRight" />
                                <!-- Loading indicator -->
                                <TextBlock Text="{x:Static loc:Strings.State_Loading}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,4,0,0"
                                           Visibility="{Binding IsVariantSearchLoading, Converter={StaticResource BoolToVisConv}}" />
                                <!-- Hint / no-results note -->
                                <TextBlock Text="{Binding VariantSearchNote}"
                                           FontFamily="{StaticResource PrimaryFont}"
                                           FontSize="{StaticResource FontSizeSmall}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding VariantSearchNote, Converter={StaticResource StringNotEmptyToVis}}" />
                                <!-- Results list -->
                                <ListBox ItemsSource="{Binding VariantSearchResults}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         MaxHeight="220"
                                         Visibility="{Binding HasVariantSearchResults, Converter={StaticResource BoolToVisConv}}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,6" Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.SelectVariantForLineCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                  CommandParameter="{Binding}" />
                                                </Border.InputBindings>
                                                <DockPanel>
                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                                                        <TextBlock Text="{Binding ProductName}" FontFamily="{StaticResource PrimaryFont}" />
                                                        <TextBlock Text="{Binding Color, StringFormat=' ({0})'}"
                                                                   Visibility="{Binding Color, Converter={StaticResource StringNotEmptyToVis}}" />
                                                        <TextBlock Text="{Binding Size, StringFormat=' [{0}]'}"
                                                                   Visibility="{Binding Size, Converter={StaticResource StringNotEmptyToVis}}" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Sku}" FlowDirection="LeftToRight"
                                                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                        <!-- Error -->
                        <TextBlock Text="{Binding FormError}"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,8"
                                   Visibility="{Binding FormError, Converter={StaticResource StringNotEmptyToVis}}" />

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="{x:Static loc:Strings.Action_Save}"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="24,8" Margin="0,0,8,0"
                                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvBool}}" />
                            <Button Content="{x:Static loc:Strings.Action_Cancel}"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="24,8" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Busy overlay -->
        <controls:BusyOverlay Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConv}}" />
    </Grid>
</UserControl>
