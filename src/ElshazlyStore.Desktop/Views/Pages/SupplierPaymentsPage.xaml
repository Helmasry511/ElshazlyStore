<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.SupplierPaymentsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SupplierPaymentsViewModel}"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">

    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}" />
    </UserControl.InputBindings>

    <Grid>
        <!-- ═══ Main list view ═══ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="{x:Static loc:Strings.Nav_SupplierPayments}"
                       Style="{StaticResource PageTitleStyle}"
                       HorizontalAlignment="Center"
                       Margin="24,16,24,8" />

            <!-- Notification Bar -->
            <controls:NotificationBar Grid.Row="1" x:Name="PageNotification"
                                      Message="{Binding NotificationMessage}"
                                      NotificationType="{Binding NotificationType}"
                                      Margin="24,0,24,4" />

            <!-- Toolbar -->
            <DockPanel Grid.Row="2" Margin="24,0,24,8">
                <Button Content="{x:Static loc:Strings.Payment_CreateNew}"
                        Command="{Binding OpenCreateCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Visibility="{Binding CanWrite, Converter={StaticResource BoolToVisConv}}" />
                <Button Content="{x:Static loc:Strings.Action_Refresh}"
                        Command="{Binding RefreshCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,8"
                        DockPanel.Dock="Left"
                        Margin="4,0,0,0" />
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource SearchTextBoxStyle}"
                         DockPanel.Dock="Right"
                         Margin="8,0,0,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Border />
            </DockPanel>

            <!-- DataGrid -->
            <DataGrid Grid.Row="3"
                      ItemsSource="{Binding Items}"
                      Style="{StaticResource ThemedDataGridStyle}"
                      ColumnHeaderStyle="{StaticResource ThemedDataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource ThemedDataGridCellStyle}"
                      RowStyle="{StaticResource ThemedDataGridRowStyle}"
                      Margin="24,0"
                      Visibility="{Binding HasError, Converter={StaticResource InverseBoolToVisConv}}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Payment_Number}" Binding="{Binding PaymentNumber}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Purchase_Supplier}" Binding="{Binding PartyName}" Width="*" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Payment_Amount}" Binding="{Binding Amount, StringFormat=N2}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Payment_Method}" Binding="{Binding MethodDisplay}" Width="100" />
                    <DataGridTextColumn Header="{x:Static loc:Strings.Payment_Reference}" Binding="{Binding Reference}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="{x:Static loc:Strings.Field_Date}" Binding="{Binding DateDisplay}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FlowDirection" Value="LeftToRight" />
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="{x:Static loc:Strings.Field_Actions}" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{x:Static loc:Strings.Payment_PrintReceipt}"
                                        Command="{Binding DataContext.PrintPaymentCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Padding="8,4" Margin="2,0" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Empty / Error states -->
            <controls:EmptyState Grid.Row="3"
                                 Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisConv}}" />
            <controls:ErrorDisplay Grid.Row="3"
                                   Message="{Binding ErrorMessage}"
                                   RetryCommand="{Binding RefreshCommand}"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolToVisConv}}" />

            <!-- Paging -->
            <DockPanel Grid.Row="4" Margin="24,8">
                <TextBlock Text="{Binding PagingInfo}"
                           FontFamily="{StaticResource PrimaryFont}"
                           FontSize="{StaticResource FontSizeSmall}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Right" />
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="{x:Static loc:Strings.Paging_First}" Command="{Binding FirstPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Previous}" Command="{Binding PreviousPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Next}" Command="{Binding NextPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                    <Button Content="{x:Static loc:Strings.Paging_Last}" Command="{Binding LastPageCommand}" Style="{StaticResource SecondaryButtonStyle}" Padding="8,4" Margin="2,0" />
                </StackPanel>
                <Border />
            </DockPanel>
        </Grid>

        <!-- ═══ MODAL: Create Payment ═══ -->
        <Grid Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisConv}}">
            <Border Background="#80000000" />
            <Border Background="{DynamicResource ContentBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    MaxWidth="550"
                    MaxHeight="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="24,20" MaxWidth="500">
                        <!-- Header -->
                        <DockPanel Margin="0,0,0,16">
                            <Button Content="✕"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="8,4"
                                    DockPanel.Dock="Left"
                                    FontSize="14" />
                            <TextBlock Text="{x:Static loc:Strings.Payment_FormTitle}"
                                       Style="{StaticResource PageTitleStyle}"
                                       HorizontalAlignment="Center"
                                       Margin="0" />
                        </DockPanel>

                        <!-- Supplier typeahead -->
                        <TextBlock Text="{x:Static loc:Strings.Purchase_Supplier}" Style="{StaticResource FormLabelStyle}" />
                        <Grid Margin="0,0,0,12">
                            <TextBox Text="{Binding SupplierSearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ThemedTextBoxStyle}" />
                            <Popup IsOpen="{Binding HasSupplierSearchResults}"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Grid}}"
                                   Placement="Bottom"
                                   MaxHeight="220"
                                   StaysOpen="False">
                                <Border Background="{DynamicResource ContentBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        MinWidth="300">
                                    <ListBox ItemsSource="{Binding SupplierSearchResults}"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.SelectSupplierCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                      CommandParameter="{Binding}" />
                                                    </Border.InputBindings>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource PrimaryFont}" />
                                                        <TextBlock Text=" — " Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="{Binding Code}" FlowDirection="LeftToRight"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" FontFamily="{StaticResource PrimaryFont}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- Amount -->
                        <TextBlock Text="{x:Static loc:Strings.Payment_Amount}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormAmount, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,12"
                                 FlowDirection="LeftToRight" />

                        <!-- Method -->
                        <TextBlock Text="{x:Static loc:Strings.Payment_Method}" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox ItemsSource="{Binding PaymentMethods}"
                                  SelectedItem="{Binding FormMethod}"
                                  Style="{StaticResource ThemedComboBoxStyle}"
                                  Margin="0,0,0,12" />

                        <!-- Wallet name (optional) -->
                        <TextBlock Text="{x:Static loc:Strings.Payment_WalletName}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormWalletName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,12" />

                        <!-- Reference -->
                        <TextBlock Text="{x:Static loc:Strings.Payment_Reference}" Style="{StaticResource FormLabelStyle}" />
                        <TextBox Text="{Binding FormReference, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource ThemedTextBoxStyle}" Margin="0,0,0,12"
                                 FlowDirection="LeftToRight" />

                        <!-- Error -->
                        <TextBlock Text="{Binding FormError}"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="{StaticResource FontSizeSmall}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,8"
                                   Visibility="{Binding FormError, Converter={StaticResource StringNotEmptyToVis}}" />

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="{x:Static loc:Strings.Action_Save}"
                                    Command="{Binding SaveCommand}"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Padding="24,8" Margin="0,0,8,0"
                                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvBool}}" />
                            <Button Content="{x:Static loc:Strings.Action_Cancel}"
                                    Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Padding="24,8" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Busy overlay -->
        <controls:BusyOverlay Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisConv}}" />
    </Grid>
</UserControl>
