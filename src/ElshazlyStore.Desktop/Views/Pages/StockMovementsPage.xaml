<UserControl x:Class="ElshazlyStore.Desktop.Views.Pages.StockMovementsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ElshazlyStore.Desktop.ViewModels"
             xmlns:controls="clr-namespace:ElshazlyStore.Desktop.Views.Controls"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:StockMovementsViewModel}"
             Loaded="OnLoaded"
             FlowDirection="RightToLeft">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16" MaxWidth="900" HorizontalAlignment="Center">

            <!-- Page title -->
            <TextBlock Text="{x:Static loc:Strings.Stock_MovementsTitle}"
                       Style="{StaticResource PageTitleStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,16" />

            <!-- Movement Type -->
            <TextBlock Text="{x:Static loc:Strings.Field_MovementType}" Style="{StaticResource FormLabelStyle}" />
            <ComboBox ItemsSource="{Binding MovementTypes}"
                      SelectedItem="{Binding SelectedMovementType}"
                      DisplayMemberPath="Display"
                      Style="{StaticResource ThemedComboBoxStyle}"
                      MinWidth="200"
                      VerticalContentAlignment="Center"
                      FontFamily="{StaticResource PrimaryFont}"
                      FontSize="{StaticResource FontSizeNormal}"
                      Margin="0,0,0,12" />

            <!-- Reference -->
            <TextBlock Text="{x:Static loc:Strings.Field_Reference}" Style="{StaticResource FormLabelStyle}" />
            <TextBox Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ThemedTextBoxStyle}"
                     FlowDirection="LeftToRight"
                     Margin="0,0,0,12" />

            <!-- Notes -->
            <TextBlock Text="{x:Static loc:Strings.Field_Notes}" Style="{StaticResource FormLabelStyle}" />
            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource ThemedTextBoxStyle}"
                     AcceptsReturn="True"
                     MinHeight="60"
                     Margin="0,0,0,16" />

            <!-- Lines header -->
            <DockPanel Margin="0,0,0,8">
                <TextBlock Text="سطور الحركة"
                           Style="{StaticResource FormLabelStyle}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <Button Content="{x:Static loc:Strings.Action_AddLine}"
                        Command="{Binding AddLineCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="12,6"
                        DockPanel.Dock="Left"
                        Margin="12,0,0,0" />
                <Button Content="{x:Static loc:Strings.Action_RefreshWarehouses}"
                        Command="{Binding RefreshWarehousesCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Padding="12,6"
                        DockPanel.Dock="Left"
                        Margin="8,0,0,0"
                        IsEnabled="{Binding IsRefreshingWarehouses, Converter={StaticResource InvBool}}" />
                <Border />
            </DockPanel>

            <!-- Lines list -->
            <ItemsControl ItemsSource="{Binding Lines}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource MediumCornerRadius}"
                                Padding="12"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <!-- Variant display / pick -->
                                    <TextBlock Text="{x:Static loc:Strings.Field_Variant}" Style="{StaticResource FormLabelStyle}" />

                                    <!-- Already-selected variant display -->
                                    <Border Visibility="{Binding VariantDisplay, Converter={StaticResource StringNotEmptyToVis}}"
                                            Background="{DynamicResource SidebarBackgroundBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{StaticResource SmallCornerRadius}"
                                            Padding="8,4"
                                            Margin="0,0,0,8">
                                        <TextBlock Text="{Binding VariantDisplay}"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   FontSize="{StaticResource FontSizeNormal}" />
                                    </Border>

                                    <!-- Variant search TextBox + popup (shown when no variant selected) -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding VariantDisplay, Converter={StaticResource StringNotEmptyToVis}}" Value="Visible">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <TextBox x:Name="MovLineVariantSearch"
                                                 Text="{Binding DataContext.VariantSearchText, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                 Style="{StaticResource ThemedTextBoxStyle}"
                                                 MinWidth="200"
                                                 VerticalContentAlignment="Center"
                                                 GotFocus="OnLineVariantSearchFocused"
                                                 Tag="{Binding}" />
                                        <!-- Placeholder hint -->
                                        <TextBlock Text="{x:Static loc:Strings.Stock_VariantSearchHint}"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{DynamicResource DisabledTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"
                                                   IsHitTestVisible="False">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.VariantSearchText, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Variant search results dropdown -->
                                        <Popup IsOpen="{Binding DataContext.HasVariantSearchResults, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               StaysOpen="False"
                                               Placement="Bottom"
                                               MaxHeight="280">
                                            <Border Background="{DynamicResource ContentBackgroundBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="{StaticResource SmallCornerRadius}"
                                                    MinWidth="300"
                                                    MaxHeight="270">
                                                <ListBox ItemsSource="{Binding DataContext.VariantSearchResults, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         Background="{DynamicResource ContentBackgroundBrush}"
                                                         BorderThickness="0">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="8,6" Cursor="Hand">
                                                                <Border.InputBindings>
                                                                    <MouseBinding MouseAction="LeftClick"
                                                                                  Command="{Binding DataContext.SelectVariantForLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                  CommandParameter="{Binding}" />
                                                                </Border.InputBindings>
                                                                <DockPanel>
                                                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                                                                        <TextBlock Text="{Binding ProductName}"
                                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                                   FontSize="{StaticResource FontSizeNormal}" />
                                                                        <!-- Color / Size meta -->
                                                                        <TextBlock FontFamily="{StaticResource PrimaryFont}"
                                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                                   Margin="6,0,0,0"
                                                                                   VerticalAlignment="Center"
                                                                                   Visibility="{Binding Color, Converter={StaticResource StringNotEmptyToVis}}">
                                                                            <Run Text="(" /><Run Text="{Binding Color, Mode=OneWay}" /><Run Text=")" />
                                                                        </TextBlock>
                                                                        <TextBlock FontFamily="{StaticResource PrimaryFont}"
                                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                                   Margin="4,0,0,0"
                                                                                   VerticalAlignment="Center"
                                                                                   Visibility="{Binding Size, Converter={StaticResource StringNotEmptyToVis}}">
                                                                            <Run Text="[" /><Run Text="{Binding Size, Mode=OneWay}" /><Run Text="]" />
                                                                        </TextBlock>
                                                                    </StackPanel>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                                        <TextBlock Text="{Binding Sku}"
                                                                                   FlowDirection="LeftToRight"
                                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                                                        <TextBlock Text="{Binding Barcode}"
                                                                                   FlowDirection="LeftToRight"
                                                                                   FontFamily="{StaticResource PrimaryFont}"
                                                                                   FontSize="{StaticResource FontSizeSmall}"
                                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                                   Margin="12,0,0,0"
                                                                                   Visibility="{Binding Barcode, Converter={StaticResource StringNotEmptyToVis}}" />
                                                                    </StackPanel>
                                                                </DockPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Border>
                                        </Popup>
                                    </Grid>

                                    <!-- Warehouse: single picker for non-transfer -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsTransferMode, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="{x:Static loc:Strings.Field_Warehouse}" Style="{StaticResource FormLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding DataContext.Warehouses, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  SelectedItem="{Binding SelectedWarehouse}"
                                                  DisplayMemberPath="DisplayText"
                                                  Style="{StaticResource ThemedComboBoxStyle}"
                                                  MinWidth="160"
                                                  VerticalContentAlignment="Center"
                                                  FontFamily="{StaticResource PrimaryFont}"
                                                  FontSize="{StaticResource FontSizeNormal}"
                                                  Margin="0,0,0,4" />
                                    </StackPanel>

                                    <!-- Transfer: From/To warehouse pickers -->
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsTransferMode, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <WrapPanel Margin="0,0,0,4">
                                            <!-- From Warehouse -->
                                            <StackPanel Margin="0,0,16,4">
                                                <TextBlock Text="{x:Static loc:Strings.Field_FromWarehouse}" Style="{StaticResource FormLabelStyle}" />
                                                <ComboBox ItemsSource="{Binding DataContext.Warehouses, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          SelectedItem="{Binding SelectedFromWarehouse}"
                                                          DisplayMemberPath="DisplayText"
                                                          Style="{StaticResource ThemedComboBoxStyle}"
                                                          MinWidth="160"
                                                          VerticalContentAlignment="Center"
                                                          FontFamily="{StaticResource PrimaryFont}"
                                                          FontSize="{StaticResource FontSizeNormal}" />
                                            </StackPanel>
                                            <!-- To Warehouse -->
                                            <StackPanel Margin="0,0,0,4">
                                                <TextBlock Text="{x:Static loc:Strings.Field_ToWarehouse}" Style="{StaticResource FormLabelStyle}" />
                                                <ComboBox ItemsSource="{Binding DataContext.Warehouses, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          SelectedItem="{Binding SelectedToWarehouse}"
                                                          DisplayMemberPath="DisplayText"
                                                          Style="{StaticResource ThemedComboBoxStyle}"
                                                          MinWidth="160"
                                                          VerticalContentAlignment="Center"
                                                          FontFamily="{StaticResource PrimaryFont}"
                                                          FontSize="{StaticResource FontSizeNormal}" />
                                            </StackPanel>
                                        </WrapPanel>
                                        <!-- Transfer route display text -->
                                        <TextBlock Text="{Binding TransferRouteDisplay}"
                                                   FontFamily="{StaticResource PrimaryFont}"
                                                   FontSize="{StaticResource FontSizeSmall}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Margin="0,2,0,4"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding TransferRouteDisplay, Converter={StaticResource StringNotEmptyToVis}}" />
                                    </StackPanel>

                                    <!-- Default warehouse hint (display-only) -->
                                    <TextBlock Text="{Binding DefaultWarehouseDisplay}"
                                               FontFamily="{StaticResource PrimaryFont}"
                                               FontSize="{StaticResource FontSizeSmall}"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,0,0,8"
                                               Visibility="{Binding DefaultWarehouseDisplay, Converter={StaticResource StringNotEmptyToVis}}" />

                                    <!-- Quantity & Cost in a row -->
                                    <WrapPanel Margin="0,0,0,4">
                                        <StackPanel Margin="0,0,16,4">
                                            <TextBlock Text="{x:Static loc:Strings.Field_QuantityDelta}" Style="{StaticResource FormLabelStyle}" />
                                            <TextBox Text="{Binding QuantityDelta, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ThemedTextBoxStyle}"
                                                     FlowDirection="LeftToRight"
                                                     MinWidth="100" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,16,4">
                                            <TextBlock Text="{x:Static loc:Strings.Field_UnitCost}" Style="{StaticResource FormLabelStyle}" />
                                            <TextBox Text="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                                     Style="{StaticResource ThemedTextBoxStyle}"
                                                     FlowDirection="LeftToRight"
                                                     MinWidth="100" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,4">
                                            <TextBlock Text="{x:Static loc:Strings.Field_Reason}" Style="{StaticResource FormLabelStyle}" />
                                            <TextBox Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ThemedTextBoxStyle}"
                                                     MinWidth="150" />
                                        </StackPanel>
                                    </WrapPanel>
                                </StackPanel>

                                <!-- Remove button -->
                                <Button Grid.Column="1"
                                        Content="{x:Static loc:Strings.Action_RemoveLine}"
                                        Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Padding="8,4"
                                        VerticalAlignment="Top"
                                        Margin="8,0,0,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Error message -->
            <TextBlock Text="{Binding FormError}"
                       Foreground="{DynamicResource ErrorBrush}"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="{StaticResource FontSizeSmall}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,8"
                       Visibility="{Binding FormError, Converter={StaticResource StringNotEmptyToVis}}" />

            <!-- Post button -->
            <Button Content="{x:Static loc:Strings.Action_Post}"
                    Command="{Binding PostCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="24,10"
                    HorizontalAlignment="Right"
                    Margin="0,8,0,0"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvBool}}" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
