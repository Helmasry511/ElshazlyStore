<UserControl x:Class="ElshazlyStore.Desktop.Views.Controls.BusyOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <!-- Semi-transparent overlay with centered spinner text -->
    <Border Background="#60000000">
        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center">
            <!-- Simple rotating indicator -->
            <Border Width="40" Height="40"
                    CornerRadius="20"
                    BorderBrush="{DynamicResource AccentBrush}"
                    BorderThickness="3"
                    Margin="0,0,0,16"
                    HorizontalAlignment="Center">
                <Border.RenderTransform>
                    <RotateTransform Angle="0" CenterX="20" CenterY="20" />
                </Border.RenderTransform>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 From="0" To="360"
                                                 Duration="0:0:1" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
            </Border>
            <TextBlock Text="{x:Static loc:Strings.State_Loading}"
                       FontFamily="{StaticResource PrimaryFont}"
                       FontSize="{StaticResource FontSizeMedium}"
                       Foreground="White"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Border>
</UserControl>
