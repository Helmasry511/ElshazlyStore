<UserControl x:Class="ElshazlyStore.Desktop.Views.Controls.EmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:ElshazlyStore.Desktop.Localization"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="0,40">
        <!-- Empty box icon -->
        <Path Data="M20,2 H4 C3,2 2,2.9 2,4 V7 C2,7.7 2.4,8.4 3,8.7 V20 C3,21.1 3.9,22 5,22 H19 C20.1,22 21,21.1 21,20 V8.7 C21.6,8.4 22,7.7 22,7 V4 C22,2.9 21,2 20,2 Z M14,14 H10 V12 H14 V14 Z M20,7 H4 V4 H20 V7 Z"
              Fill="{DynamicResource DisabledTextBrush}"
              Width="48" Height="48"
              Stretch="Uniform"
              HorizontalAlignment="Center"
              Margin="0,0,0,16" />

        <TextBlock Text="{x:Static loc:Strings.State_Empty}"
                   FontFamily="{StaticResource PrimaryFont}"
                   FontSize="{StaticResource FontSizeMedium}"
                   Foreground="{DynamicResource DisabledTextBrush}"
                   HorizontalAlignment="Center" />
    </StackPanel>
</UserControl>
