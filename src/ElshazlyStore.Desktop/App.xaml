<Application x:Class="ElshazlyStore.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Index 0: Theme (swapped at runtime by ThemeService) -->
                <ResourceDictionary Source="Resources/Themes/DarkTheme.xaml" />
                <!-- Index 1: Shared styles (always loaded) -->
                <ResourceDictionary Source="Resources/Themes/SharedStyles.xaml" />
                <!-- Index 2: DataGrid styles -->
                <ResourceDictionary Source="Resources/Themes/DataGridStyles.xaml" />
                <!-- Index 3: Form styles -->
                <ResourceDictionary Source="Resources/Themes/FormStyles.xaml" />
                <!-- Index 4: Dialog + Badge styles -->
                <ResourceDictionary Source="Resources/Themes/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
