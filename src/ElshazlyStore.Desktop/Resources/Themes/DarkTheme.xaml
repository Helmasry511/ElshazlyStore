<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ Dark Theme Colors ═══ -->

    <!-- Shell / Chrome -->
    <Color x:Key="WindowBackgroundColor">#1E1E2E</Color>
    <Color x:Key="SidebarBackgroundColor">#181825</Color>
    <Color x:Key="TopBarBackgroundColor">#1E1E2E</Color>
    <Color x:Key="ContentBackgroundColor">#242438</Color>

    <!-- Inputs -->
    <Color x:Key="InputBackgroundColor">#1A2333</Color>
    <Color x:Key="InputBorderColor">#73839D</Color>
    <Color x:Key="InputSelectionColor">#8AB4F8</Color>

    <!-- Cashier emphasis -->
    <Color x:Key="CashierAccentBackgroundColor">#13263D</Color>
    <Color x:Key="CashierAccentBorderColor">#355C84</Color>

    <!-- Text -->
    <Color x:Key="PrimaryTextColor">#E6ECFF</Color>
    <Color x:Key="SecondaryTextColor">#BEC8E4</Color>
    <Color x:Key="DisabledTextColor">#585B70</Color>

    <!-- Accent -->
    <Color x:Key="AccentColor">#89B4FA</Color>
    <Color x:Key="AccentHoverColor">#74C7EC</Color>
    <Color x:Key="AccentPressedColor">#89DCEB</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#313244</Color>
    <Color x:Key="BorderHoverColor">#45475A</Color>

    <!-- Nav Items -->
    <Color x:Key="NavItemHoverColor">#313244</Color>
    <Color x:Key="NavItemActiveColor">#45475A</Color>

    <!-- Status -->
    <Color x:Key="SuccessColor">#A6E3A1</Color>
    <Color x:Key="WarningColor">#F9E2AF</Color>
    <Color x:Key="ErrorColor">#F38BA8</Color>

    <!-- Cards / Surfaces -->
    <Color x:Key="CardBackgroundColor">#2A2A3D</Color>
    <Color x:Key="CardHoverColor">#313244</Color>

    <!-- Scrollbar -->
    <Color x:Key="ScrollBarColor">#45475A</Color>
    <Color x:Key="ScrollBarHoverColor">#585B70</Color>

    <!-- ═══ SolidColorBrushes ═══ -->
    <SolidColorBrush x:Key="WindowBackgroundBrush"       Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush"       Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="TopBarBackgroundBrush"        Color="{StaticResource TopBarBackgroundColor}" />
    <SolidColorBrush x:Key="ContentBackgroundBrush"       Color="{StaticResource ContentBackgroundColor}" />
    <SolidColorBrush x:Key="InputBackgroundBrush"         Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="InputBorderBrush"             Color="{StaticResource InputBorderColor}" />
    <SolidColorBrush x:Key="InputSelectionBrush"          Color="{StaticResource InputSelectionColor}" />
    <SolidColorBrush x:Key="CashierAccentBackgroundBrush" Color="{StaticResource CashierAccentBackgroundColor}" />
    <SolidColorBrush x:Key="CashierAccentBorderBrush"     Color="{StaticResource CashierAccentBorderColor}" />

    <SolidColorBrush x:Key="PrimaryTextBrush"             Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryTextBrush"           Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="DisabledTextBrush"            Color="{StaticResource DisabledTextColor}" />

    <SolidColorBrush x:Key="AccentBrush"                  Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush"             Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush"           Color="{StaticResource AccentPressedColor}" />

    <SolidColorBrush x:Key="BorderBrush"                  Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="BorderHoverBrush"             Color="{StaticResource BorderHoverColor}" />

    <SolidColorBrush x:Key="NavItemHoverBrush"            Color="{StaticResource NavItemHoverColor}" />
    <SolidColorBrush x:Key="NavItemActiveBrush"           Color="{StaticResource NavItemActiveColor}" />

    <SolidColorBrush x:Key="SuccessBrush"                 Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush"                 Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush"                   Color="{StaticResource ErrorColor}" />

    <SolidColorBrush x:Key="CardBackgroundBrush"          Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="CardHoverBrush"               Color="{StaticResource CardHoverColor}" />

    <SolidColorBrush x:Key="ScrollBarBrush"               Color="{StaticResource ScrollBarColor}" />
    <SolidColorBrush x:Key="ScrollBarHoverBrush"          Color="{StaticResource ScrollBarHoverColor}" />

</ResourceDictionary>
