{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=elshazlystore;Username=postgres;Password=CHANGE_ME"
  },
  "Jwt": {
    "Secret": "CHANGE-THIS-TO-A-SECURE-SECRET-KEY-AT-LEAST-32-CHARS!!",
    "Issuer": "ElshazlyStore",
    "Audience": "ElshazlyStore.Desktop",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "RequestLimits": {
    "MaxRequestBodyMB": 10,
    "MaxMultipartMB": 10
  },
  "AttachmentStorage": {
    "RootPath": "CustomerAttachments"
  },
  "Performance": {
    "CommandTimeoutSeconds": 30,
    "SlowRequestThresholdMs": 500
  },
  "AllowedHosts": "*"
}
